  "translations": [
    [ { "text": "最近，選擇對環境與勞動環境有所顧慮的商品的「道德消費」這種觀念正逐漸普及。", "word": "エシカル消費" } ],
    [ { "text": "以前購物時比較重視價格便宜，但現在關心生產過程是否對環境造成負擔、勞工是否受到正當對待的人似乎變多了。", "word": "労働者" } ],
    [ { "text": "當然，道德消費的商品價格往往偏高，並非人人都能馬上實踐。", "word": "実践する" } ],
    [ { "text": "即便如此，我覺得在能力範圍內重新檢視自己的選擇，或許能成為讓整體社會漸漸變好的契機。", "word": "きっかけ" } ]
