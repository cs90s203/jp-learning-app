  "translations": [
    [ { "text": "我家附近有一間老式的錢湯（大眾澡堂）。", "word": "銭湯" } ],
    [ { "text": "家裡雖然有浴室，但偶爾會想悠閒地泡在寬敞的浴池裡，於是就會去那裡。", "word": "浸かる" } ],
    [ { "text": "櫃檯的老奶奶總是笑臉迎人地跟我打招呼，和常客們閒聊也是一種樂趣。", "word": "世間話" } ],
    [ { "text": "尤其是工作疲累的日子，在大浴池裡伸展手腳，就覺得一天的疲勞都消散了。", "word": "気がする" } ],
    [ { "text": "聽說最近利用錢湯的年輕人也增加了，希望這個文化今後也能持續下去。", "word": "続く" } ]
  ],
