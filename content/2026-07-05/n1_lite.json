  "translations": [
    [ { "text": "日本社會常被要求「察言觀色」，比起個人意見，人們往往優先考慮不擾亂團體和諧、與周遭保持一致的傾向。", "word": "同調" } ],
    [ { "text": "這種同儕壓力雖然在維持組織秩序上發揮了一定作用，但對持有少數意見或與多數價值觀不同的人來說，卻可能成為強烈窒息感的原因。", "word": "同調圧力" } ],
    [ { "text": "近年來雖然尊重多元性的風氣逐漸擴散，但在實際的職場和學校中，「和大家一樣」仍常在無形中被重視。", "word": "多様性" } ],
    [ { "text": "尤其在社群媒體普及的現代，據說這種壓力變得更容易被看見。", "word": "普及する" } ],
    [ { "text": "即使難以完全消除同儕壓力本身，一點一點擴大接納不同意見的空間，或許正是緩解生存不易之感的第一步。", "word": "生きづらさ" } ]
