  "translations": [
    [ { "text": "日圓貶值的持續發展，對家庭經濟造成的影響日益嚴重。", "word": "影響" } ],
    [ { "text": "依賴進口的食品與能源價格普遍上漲，家庭的負擔正穩健地加重。", "word": "負担" } ],
    [ { "text": "尤其是原物料大多仰賴海外進口的食品製造商，被迫將成本上升的部分轉嫁到產品價格上。", "word": "転嫁する" } ],
    [ { "text": "另一方面，對出口企業而言，日圓貶值反而成為有利條件，業績好轉的案例也不少。", "word": "追い風" } ],
    [ { "text": "如此一來，受惠於日圓貶值的行業與受到打擊的行業形成明顯對比，政府物價對策的實際成效也備受質疑。", "word": "明暗" } ],
    [ { "text": "今後，若薪資上升跟不上物價上漲的速度，實質生活水準的下降恐怕難以避免。", "word": "避ける" } ],
    [ { "text": "為了守護家計，選擇進口依賴度較低的商品、記家計簿檢視支出等巧思都不可或缺。", "word": "工夫" } ]
  ]
}
