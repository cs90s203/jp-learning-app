  "translations": [
    [ { "text": "最近，休假日逛二手唱片行變成了我的興趣。", "word": "趣味" } ],
    [ { "text": "在老咖啡廳附近的一間小店裡，店主會很詳細地跟我介紹爵士唱片。", "word": "教える" } ],
    [ { "text": "雖然價格有時稍微偏貴，但光是看著唱片封套的設計就很開心。", "word": "眺める" } ],
