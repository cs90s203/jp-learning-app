  "translations": [
    [ { "text": "上星期六，我和朋友在河邊烤肉。", "word": "バーベキュー" } ],
    [ { "text": "因為天氣很好，大家都看起來很開心。", "word": "楽しい" } ],
    [ { "text": "大家一起幫忙準備，烤肉、切菜。", "word": "手伝う" } ],
    [ { "text": "因為也有好久不見的朋友來，能聊很多話讓我很開心。", "word": "できる" } ],
