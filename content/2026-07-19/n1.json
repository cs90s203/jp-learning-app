  "translations": [
    [ { "text": "男性的育嬰假請休率雖然近年來有上升的趨勢，但與女性之間依然存在很大的差距。", "word": "開き" } ],
    [ { "text": "政府雖然多次修法，致力於完善便於請休育嬰假的環境，但實際上許多希望請假的男性員工，還是因為顧慮職場氛圍而遲遲不敢申請，這是現實情況。", "word": "実情" } ],
    [ { "text": "尤其在中小企業中，由於人力沒有餘裕，難以確保代替人力，制度流於形式的案例也不在少數。", "word": "形骸化する" } ],
    [ { "text": "此外，擔心得不到上司與同事理解的顧慮，也是讓人猶豫請假與否的一大因素。", "word": "懸念" } ],
    [ { "text": "要打破這樣的局面，除了完善制度之外，更不可或缺的是讓「請育嬰假是理所當然的」這種觀念在整個組織中扎根。", "word": "根づく" } ],
    [ { "text": "企業文化的變革雖然需要時間，但經營階層率先請育嬰假等具體行動，或許正是推動改變的第一步。", "word": "後押しする" } ]
  ]
