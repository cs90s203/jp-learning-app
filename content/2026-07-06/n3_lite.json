  "translations": [
    [ { "text": "我家附近有一間小小的蔬果店。", "word": "八百屋さん" } ],
    [ { "text": "店主爺爺總是很有精神地跟人打招呼。", "word": "挨拶する" } ],
    [ { "text": "蔬菜雖然比超市貴一點，但是很新鮮又好吃。", "word": "新鮮" } ],
    [ { "text": "尤其是當季水果一擺出來，就會不小心買太多。", "word": "買いすぎる" } ],
    [ { "text": "因為從小時候就一直在同一個地方，總覺得有種懷念的心情。", "word": "懐かしい" } ],
    [ { "text": "就算忙碌的時候，順道去那間店也會覺得心情平靜下來。", "word": "落ち着く" } ],
    [ { "text": "是今後也想珍惜的地方。", "word": "大切にする" } ]
  ],
