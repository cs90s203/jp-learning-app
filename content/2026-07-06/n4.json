  "translations": [
    [ { "text": "上個月和姊姊去了溫泉旅行。", "word": "温泉旅行" } ],
    [ { "text": "又搭電車又搭巴士，抵達了山裡的一間小旅館。", "word": "旅館" } ],
    [ { "text": "泡了溫泉之後，疲勞都消除了，感覺非常舒服。", "word": "気持ちいい" } ],
    [ { "text": "姊姊喜歡拍照，所以在風景漂亮的地方拍了很多照片。", "word": "好き" } ],
    [ { "text": "晚上能吃到好吃的料理，真的成了一趟開心的旅行。", "word": "楽しい" } ],
    [ { "text": "還想再和姊姊兩個人一起去旅行。", "word": "二人" } ]
