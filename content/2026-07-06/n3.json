  "translations": [
    [ { "text": "最近試著開始了晨間活動。", "word": "朝活" } ],
    [ { "text": "以前總覺得「早上無論如何都起不來」，但把鬧鐘放到窗邊之後，意外地能輕鬆起床了。", "word": "起きる" } ],
    [ { "text": "早上邊沖咖啡邊確認當天的行程。", "word": "確認する" } ],
    [ { "text": "和以前當夜貓子的時候相比，頭腦變得清爽，工作效率好像也提升了。", "word": "効率" } ],
    [ { "text": "話雖如此，假日還是會不小心睡過頭，還不能說已經完全養成習慣。", "word": "習慣化する" } ],
    [ { "text": "即使如此，還是想暫時繼續維持這個生活節奏。", "word": "生活リズム" } ]
