  "translations": [
    [
      {
        "text": "從上星期開始，久違地在規劃一個人的旅行。",
        "word": "一人旅"
      }
    ],
    [
      {
        "text": "目的地還在猶豫，但「想在安靜的溫泉小鎮悠閒待著」的念頭最強烈。",
        "word": "気持ち"
      }
    ],
    [
      {
        "text": "朋友常問我「一個人沒問題嗎」，但不用配合任何人的行程，正是一個人旅行最大的魅力。",
        "word": "魅力"
      }
    ],
    [
      {
        "text": "當然也會有感到寂寞的時候吧，但我打算連那份寂寞也一起享受。",
        "word": "楽しむ"
      }
    ],
    [
      {
        "text": "隨著出發的日子接近，心情也一點一點地興奮起來了。",
        "word": "わくわく"
      }
    ]
  ]
}