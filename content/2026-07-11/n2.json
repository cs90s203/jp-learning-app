  "translations": [
    [
      {
        "text": "近年，男性的育嬰假取得比率穩健上升。",
        "word": "上昇する"
      }
    ],
    [
      {
        "text": "根據厚生勞動省的調查，幾年前還不到一成的取得率，在法律修正與企業意識改革之下大幅提升了。",
        "word": "伸びる"
      }
    ],
    [
      {
        "text": "背景可以歸因於建立便於申請育嬰假制度的企業增加，加上男性本身的意識也逐漸改變。",
        "word": "変わる"
      }
    ],
    [
      {
        "text": "話雖如此，即使實際上想申請，仍有不少人以職場氛圍或人手不足為由而猶豫。",
        "word": "ためらう"
      }
    ],
