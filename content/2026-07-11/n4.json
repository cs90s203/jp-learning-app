  "translations": [
    [
      {
        "text": "前幾天，我和哥哥一起去附近的山上健行了。",
        "word": "行く"
      }
    ],
    [
      {
        "text": "雖然路有點陡峭，但看了美麗的風景、喝了冰涼的山泉水，非常開心。",
        "word": "たのしい"
      }
    ],
    [
      {
        "text": "哥哥因為習慣爬山，教了我很多東西。",
        "word": "教えてくれる"
      }
    ],
    [
      {
        "text": "多虧如此，我才能走到最後。",
        "word": "できる"
      }
    ]
  ]
