  "translations": [
    [
      {
        "text": "日本各地區都有獨特的飲食文化",
        "word": "食文化"
      },
      {
        "text": "。",
        "word": null
      }
    ],
    [
      {
        "text": "北海道以新鮮海產和乳製品聞名，",
        "word": "海産物"
      },
      {
        "text": "在觀光客中非常受歡迎",
        "word": "人気"
      },
      {
        "text": "。",
        "word": null
      }
    ],
    [
      {
        "text": "另一方面，",
        "word": "一方"
      },
      {
        "text": "關西地方多清淡的高湯料理，",
        "word": "出汁"
      },
      {
        "text": "這種文化已深深扎根",
        "word": "根付く"
      },
      {
        "text": "。",
        "word": null
      }
    ],
    [
      {
        "text": "這種地區差異，",
        "word": "地域差"
      },
      {
        "text": "據說源於氣候和歷史背景",
        "word": "背景"
      },
      {
        "text": "。",
        "word": null
      }
    ],
    [
      {
        "text": "近年日本料理被列入聯合國教科文組織的無形文化遺產，",
        "word": "無形文化遺産"
      },
      {
        "text": "因而獲得了全球的關注",
        "word": "注目"
      },
      {
        "text": "。",
        "word": null
      }
    ],
    [
      {
        "text": "和食的特徵在於珍視食材本身的味道，",
        "word": "食材"
      },
      {
        "text": "並重視季節感",
        "word": "季節感"
      },
      {
        "text": "。",
        "word": null
      }
    ],
    [
      {
        "text": "擺盤也講究美感，",
        "word": "盛り付け"
      },
      {
        "text": "外觀的美麗也被視為重要要素",
        "word": "要素"
      },
      {
        "text": "。",
        "word": null
      }
    ],
    [
      {
        "text": "據說許多造訪日本的外國人都對日本料理的多樣性和細膩感到驚訝",
        "word": "多様性"
      },
      {
        "text": "。",
        "word": null
      }
    ]
  ],
