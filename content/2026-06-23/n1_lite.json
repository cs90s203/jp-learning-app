  "translations": [
    [
      {
        "text": "在日本，人口集中都市的趨勢不斷推進，",
        "word": "都市集中"
      },
      {
        "text": "另一方面地方過疎化成為嚴重問題",
        "word": "過疎化"
      },
      {
        "text": "。",
        "word": null
      }
    ],
    [
      {
        "text": "特別是年輕世代流入都市的現象顯著，",
        "word": "若年層"
      },
      {
        "text": "成為動搖地方政府財政基礎的要因",
        "word": "財政基盤"
      },
      {
        "text": "。",
        "word": null
      }
    ],
    [
      {
        "text": "為了打破這種狀況，近年推行了「地方創生」政策",
        "word": "地方創生"
      },
      {
        "text": "。",
        "word": null
      }
    ],
    [
      {
        "text": "具體而言，",
        "word": "具体的"
      },
      {
        "text": "正在推進完善移居支援制度、活用地方振興協力隊、",
        "word": "活用"
      },
      {
        "text": "以及整備遠端工作環境等措施",
        "word": "整備"
      },
      {
        "text": "。",
        "word": null
      }
    ],
    [
      {
        "text": "然而，",
        "word": "しかしながら"
      },
      {
        "text": "這些施策的效果因地區而大相徑庭，",
        "word": "施策"
      },
      {
        "text": "仍有許多地區無法抑制人口減少",
        "word": "人口減少"
      },
      {
        "text": "。",
        "word": null
      }
    ],
    [
      {
        "text": "為了縮小都市與地方的差距，",
        "word": "格差"
      },
      {
        "text": "不能只是吸引人口，",
        "word": "人口誘致"
      },
      {
        "text": "還需要產業振興、教育醫療基礎建設整備等多方面的方法",
        "word": "アプローチ"
      },
      {
        "text": "。",
        "word": null
      }
    ],
    [
      {
        "text": "將數位技術應用於智慧城市概念推廣至地方的努力也備受關注",
        "word": "スマートシティ"
      },
      {
        "text": "。",
        "word": null
      }
    ],
    [
      {
        "text": "地方活化是日本社會整體永續發展不可或缺的課題",
        "word": "活性化"
      },
      {
        "text": "。",
        "word": null
      }
    ]
  ],
