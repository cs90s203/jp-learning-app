  "translations": [
    [
      {
        "text": "日本面臨的最大社會課題之一，",
        "word": "社会的課題"
      },
      {
        "text": "是伴隨少子高齡化而來的人口結構變容",
        "word": "少子高齢化"
      },
      {
        "text": "。",
        "word": null
      }
    ],
    [
      {
        "text": "出生率下降與平均壽命延長相互疊加，",
        "word": "出生率"
      },
      {
        "text": "導致生產年齡人口急速縮小，",
        "word": "生産年齢人口"
      },
      {
        "text": "社會保障制度的永續可能性從根本受到質疑",
        "word": "社会保障制度"
      },
      {
        "text": "。",
        "word": null
      }
    ],
    [
      {
        "text": "年金、醫療、照護的各項給付費不斷增大，",
        "word": "給付費"
      },
      {
        "text": "另一方面支撐這些制度的在職世代負擔已達臨界點",
        "word": "臨界点"
      },
      {
        "text": "。",
        "word": null
      }
    ],
    [
      {
        "text": "針對這種狀況，",
        "word": "状況"
      },
      {
        "text": "政府雖推進育兒支援擴充和工作方式改革，",
        "word": "育児支援"
      },
      {
        "text": "但其效果在專家間評價分歧",
        "word": "評価"
      },
      {
        "text": "。",
        "word": null
      }
    ],
    [
      {
        "text": "結構性問題的根底，",
        "word": "根底"
      },
      {
        "text": "是經濟不穩定性的高漲、將長時間工作視為正確的職場文化，",
        "word": "職場文化"
      },
      {
        "text": "以及固定性別角色意識的複合交織",
        "word": "性別役割意識"
      },
      {
        "text": "。",
        "word": null
      }
    ],
    [
      {
        "text": "因此，",
        "word": "したがって"
      },
      {
        "text": "「出生率的恢復需要超越個別支援措施、對社會規範本身進行變革」的論點已浮出水面",
        "word": "論点"
      },
      {
        "text": "。",
        "word": null
      }
    ],
    [
      {
        "text": "另一方面，",
        "word": "一方"
      },
      {
        "text": "外籍勞工接納擴大方面，",
        "word": "外国人労働者"
      },
      {
        "text": "由於文化摩擦和社會整合的困難性，",
        "word": "社会統合"
      },
      {
        "text": "要求謹慎討論",
        "word": "議論"
      },
      {
        "text": "。",
        "word": null
      }
    ],
    [
      {
        "text": "少子高齡化不僅是人口問題，",
        "word": "少子高齢化"
      },
      {
        "text": "更是波及日本經濟競爭力、地區社會持續性、乃至國家認同的複合性課題",
        "word": "経済競争力"
      },
      {
        "text": "。",
        "word": null
      }
    ],
    [
      {
        "text": "解決之道需要超越世代的對話，",
        "word": "対話"
      },
      {
        "text": "以及立足長遠視野的政策制定",
        "word": "政策立案"
      },
      {
        "text": "。",
        "word": null
      }
    ]
  ],
