  "translations": [
    [
      {
        "text": "近年隨著科技的快速發展，",
        "word": "テクノロジー"
      },
      {
        "text": "工作方式正在大幅改變",
        "word": "働き方"
      },
      {
        "text": "。",
        "word": null
      }
    ],
    [
      {
        "text": "尤其是新冠疫情以後，",
        "word": "コロナ禍"
      },
      {
        "text": "居家辦公廣泛普及，",
        "word": "テレワーク"
      },
      {
        "text": "產生了縮短通勤時間和移居地方等各種生活方式的變化",
        "word": "変化"
      },
      {
        "text": "。",
        "word": null
      }
    ],
    [
      {
        "text": "另一方面，",
        "word": "一方で"
      },
      {
        "text": "也有意見指出面對面溝通減少，",
        "word": "コミュニケーション"
      },
      {
        "text": "導致團隊協作出現課題",
        "word": "課題"
      },
      {
        "text": "。",
        "word": null
      }
    ],
    [
      {
        "text": "因此，",
        "word": "したがって"
      },
      {
        "text": "許多企業開始採用每週幾天到公司的混合型工作形式",
        "word": "勤務形態"
      },
      {
        "text": "。",
        "word": null
      }
    ],
    [
      {
        "text": "此外，以自由接案方式工作的人也增加了，",
        "word": "フリーランス"
      },
      {
        "text": "社會正逐漸從傳統的正職員工中心，",
        "word": "正社員"
      },
      {
        "text": "向多樣工作方式被認可的方向過渡",
        "word": "移行"
      },
      {
        "text": "。",
        "word": null
      }
    ],
    [
      {
        "text": "為了應對這樣的變化，",
        "word": "対応"
      },
      {
        "text": "個人的技能提升和自我管理能力越來越重要",
        "word": "自己管理能力"
      },
      {
        "text": "。",
        "word": null
      }
    ],
    [
      {
        "text": "企業方面，",
        "word": "企業"
      },
      {
        "text": "完善支援彈性工作方式的制度也成為當務之急",
        "word": "急務"
      },
      {
        "text": "。",
        "word": null
      }
    ]
  ],
