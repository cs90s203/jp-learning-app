  "translations": [
    [ { "text": "日本的醫療費隨著高齡化的進展逐年增加，成為壓迫國家財政的原因之一。", "word": "医療費" } ],
    [ { "text": "根據厚生勞動省的統計，國民醫療費已超過四十兆日圓，隨著高齡人口增加，今後預估將進一步膨脹。", "word": "見込む" } ],
    [ { "text": "這種狀況的背景中，存在著醫療技術高度化導致治療費高漲、長期慢性疾病管理費用增大等複合性原因。", "word": "存在する" } ],
    [ { "text": "尤其昂貴的先進醫療與新藥的出現對病患而言是一大福音，但對公共醫療保險財政卻是沉重負擔，如何在給付與負擔間取得平衡成為迫切課題。", "word": "負担" } ],
    [ { "text": "政府至今已採取提高自付比例、推廣學名藥使用等各種對策，但尚未達到根本性的解決。", "word": "対策" } ],
    [ { "text": "今後需要透過充實預防醫療來減少疾病本身的措施，以及推動地區醫療體制效率化，在抑制醫療費增長的同時維持高品質醫療。", "word": "効率化" } ],
    [ { "text": "在少子高齡化加速之際，為了不將過度負擔留給下一代，整個社會有必要討論制度應有的樣貌。", "word": "議論する" } ]
  ]
