  "translations": [
    [ { "text": "上個月和弟弟一起去山裡的溫泉旅館住宿。", "word": "温泉旅館" } ],
    [ { "text": "因為電車誤點，抵達時已經是晚上了。", "word": "遅れる" } ],
    [ { "text": "溫泉非常寬廣，還能泡到露天溫泉。", "word": "露天風呂" } ],
    [ { "text": "星星很美，弟弟卻說很冷，很快就從浴池出來了。", "word": "きれい" } ],
    [ { "text": "晚餐吃了當地的魚，也喝了日本酒，兩人都很滿足。", "word": "満足する" } ],
    [ { "text": "下次想要更悠閒地休息。", "word": "ゆっくり" } ]
