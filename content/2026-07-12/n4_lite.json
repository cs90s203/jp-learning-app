  "translations": [
    [
      {
        "text": "上星期，我和家人第一次去露營了。",
        "word": "行く"
      }
    ],
    [
      {
        "text": "搭帳篷很困難，所以請爸爸幫忙了。",
        "word": "手伝ってもらう"
      }
    ],
    [
      {
        "text": "晚上一邊生營火一邊聊天。",
        "word": "する"
      }
    ],
    [
      {
        "text": "星星非常漂亮，讓人很感動。",
        "word": "感動する"
      }
    ],
    [
      {
        "text": "下次也想邀請朋友一起去。",
