  "translations": [
    [
      {
        "text": "上星期，我和妹妹一起去了水族館。",
        "word": "行く"
      }
    ],
    [
      {
        "text": "看了大魚，也看了海豚秀，非常開心。",
        "word": "たのしい"
      }
    ],
    [
      {
        "text": "妹妹雖然喜歡魚，但看到水母就會害怕。",
        "word": "怖がる"
      }
    ],
    [
      {
        "text": "因為我牽著她的手，所以才能看到最後。",
        "word": "できる"
      }
    ],
    [
      {
        "text": "回程時，我們買了成套的玩偶。",
        "word": "買う"
      }
    ]
  ]
