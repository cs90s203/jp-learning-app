  "translations": [
    [ { "text": "近年來，全球旅遊需求回升，", "word": "需要" }, { "text": "旅客湧向特定觀光景點的", "word": "観光地" }, { "text": "「過度觀光」", "word": "オーバーツーリズム" }, { "text": "正在惡化。", "word": "深刻化する" } ],
    [ { "text": "美麗的景觀", "word": "景観" }, { "text": "與豐富的飲食文化", "word": "食文化" }, { "text": "吸引眾多人潮，", "word": "惹きつける" }, { "text": "為地區經濟帶來巨大的恩惠。", "word": "恩恵" } ],
    [ { "text": "另一方面，", "word": "一方" }, { "text": "交通的擁擠、垃圾增加、", "word": "混雑" }, { "text": "噪音等", "word": "騒音" }, { "text": "威脅居民日常生活的事態", "word": "事態" }, { "text": "也在各地發生。", "word": "生じる" } ],
    [ { "text": "如何兼顧觀光帶來的收益", "word": "収益" }, { "text": "與居民的生活品質，", "word": "質" }, { "text": "已不再是", "word": "もはや" }, { "text": "局限於一部分地區的問題。", "word": "限る" } ],
    [ { "text": "近來，", "word": "近頃" }, { "text": "也出現了藉由入場限制或住宿稅的引進", "word": "導入" }, { "text": "來調整來訪人數的", "word": "調整する" }, { "text": "地方自治體。", "word": "自治体" } ],
