  "translations": [
    [ { "text": "在地方上的小城鎮和村莊，", "word": "町" }, { "text": "人口減少", "word": "減少" }, { "text": "與高齡化", "word": "高齢化" }, { "text": "成了嚴重的問題。", "word": "深刻" } ],
    [ { "text": "年輕世代", "word": "世代" }, { "text": "為了找工作遷往都市，", "word": "都市" }, { "text": "在被留下的地區，", "word": "残す" }, { "text": "商店和學校的關閉接連發生。", "word": "閉鎖" } ],
    [ { "text": "延續祭典與傳統活動的人手不足，地區的連結也逐漸變得薄弱。", "word": "担い手" } ],
    [ { "text": "要遏止這樣的趨勢", "word": "流れ" }, { "text": "並不容易。", "word": "容易" } ],
    [ { "text": "然而，近年來重新審視當地魅力，", "word": "魅力" }, { "text": "以獨特的舉措", "word": "独自" }, { "text": "試圖找回活力的動向", "word": "取り戻す" }, { "text": "也在各地誕生。", "word": "生まれる" } ],
    [ { "text": "例如，", "word": null }, { "text": "把空屋翻修後出租給移居者，", "word": "移住者" }, { "text": "或在網路上販售特產", "word": "特産品" }, { "text": "等嘗試。", "word": "試み" } ],
    [ { "text": "不能只依賴行政，", "word": "頼る" }, { "text": "居民成為主體", "word": "主体" }, { "text": "集思廣益", "word": "出し合う" }, { "text": "是不可或缺的。", "word": "欠かす" } ],
    [ { "text": "雖然答案不會輕易得出，", "word": "答え" }, { "text": "但想憑自己之力", "word": "自分たち" }, { "text": "建立地區未來的態度，", "word": "築く" }, { "text": "或許才是最重要的吧。", "word": "大切" } ]
  ],
