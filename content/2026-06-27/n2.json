  "translations": [
    [
      {
        "text": "以新冠肺炎的流行",
        "word": "流行"
      },
      {
        "text": "為契機，",
        "word": "きっかけ"
      },
      {
        "text": "導入在家工作的企業",
        "word": "在宅勤務"
      },
      {
        "text": "急速增加。",
        "word": "増える"
      }
    ],
    [
      {
        "text": "通勤時間消失，",
        "word": "通勤"
      },
      {
        "text": "能以自己的步調工作，",
        "word": "ペース"
      },
      {
        "text": "歡迎這點的聲音很多。",
        "word": "歓迎する"
      }
    ],
    [
      {
        "text": "另一方面，",
        "word": "一方"
      },
      {
        "text": "工作與私生活的界線",
        "word": "境界"
      },
      {
        "text": "變得模糊，",
        "word": "あいまい"
      },
      {
        "text": "反而陷入長時間勞動的人",
        "word": "陥る"
      },
      {
        "text": "據說也存在。",
        "word": "いう"
      }
    ],
    [
      {
        "text": "此外，",
        "word": null
      },
      {
        "text": "與同事見面的機會",
        "word": "機会"
      },
      {
        "text": "減少，",
        "word": "減る"
      },
      {
        "text": "感到孤獨、",
        "word": "孤独"
      },
      {
        "text": "溝通變得困難等課題",
        "word": "課題"
      },
      {
        "text": "也被指出。",
        "word": "指摘する"
      }
    ],
    [
      {
        "text": "因此，",
        "word": null
      },
      {
        "text": "企業不僅要完善制度，",
        "word": "制度"
      },
      {
        "text": "還被要求抱持顧慮員工心理健康的",
        "word": "健康"
      },
      {
        "text": "態度。",
        "word": "姿勢"
      }
    ],
    [
      {
        "text": "正是在工作自由擴展的現在，",
        "word": "自由"
      },
      {
        "text": "如何維持其品質",
        "word": "保つ"
      },
      {
        "text": "正受到追問。",
        "word": "問う"
      }
    ]
  ],
