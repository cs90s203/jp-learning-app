  "translations": [
    [ { "text": "近年，包括影音串流和音樂串流在內，各種訂閱服務日益普及。", "word": "普及する" } ],
    [ { "text": "因為只要付月費就能盡情享受喜歡的內容，據說很多人都在使用。", "word": "利用する" } ],
    [ { "text": "另一方面，加入多個服務的結果，也不少見在不知不覺間支出增加的情況。", "word": "かさむ" } ],
    [ { "text": "特別是在年輕世代，同時訂閱多個服務並不罕見，家庭收支受到的影響令人擔憂。", "word": "懸念する" } ],
    [ { "text": "實際上，也有人忘記解約沒在用的服務，繼續產生不必要的花費。", "word": "忘れる" } ],
    [ { "text": "在享受便利的同時，定期檢視訂閱內容也很重要吧。", "word": "見直す" } ]
  ],
