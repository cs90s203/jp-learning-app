  "translations": [
    [ { "text": "最近開始每天早上自己做便當了。", "word": "手作りする" } ],
    [ { "text": "以前總是想著「太麻煩了」而在便利商店買，但因為持續漲價，我發現自己做反而比較便宜。", "word": "気づく" } ],
    [ { "text": "一開始很花時間、很辛苦，但習慣之後意外地開始覺得樂在其中。", "word": "慣れる" } ],
    [ { "text": "想想配色、把剩下的蔬菜用完，這種小小的巧思也很有成就感。", "word": "工夫" } ],
    [ { "text": "而且前一天多做一點起來備用的話，早上的準備也會變輕鬆。", "word": "楽になる" } ],
    [ { "text": "雖然費工夫，但對健康好、又能省錢，所以想繼續下去。", "word": "続ける" } ]
  ],
