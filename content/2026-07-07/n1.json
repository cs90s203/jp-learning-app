  "translations": [
    [ { "text": "日本各地的地方政府正面臨人口減少與高齡化這種結構性課題，連維持行政服務本身都逐漸變得困難。", "word": "直面する" } ],
    [ { "text": "曾經支撐地方經濟的基幹產業逐漸衰退，年輕世代外流的情況未見緩解，不少地方政府同時承受稅收減少與社會保障支出增加的雙重壓力。", "word": "さらされる" } ],
    [ { "text": "為了突破這種局面，部分地方政府推出了移居補助或育兒家庭優渥補助金等政策，但也有看法認為，由於難以與鄰近地方政府做出差異化，反而陷入爭奪有限資源的局面。", "word": "陥る" } ],
    [ { "text": "更根本的解決之道，或許不在於各地方政府各自為政，而是需要透過廣域合作讓行政機能更有效率，並且重新以策略性方式分配有限資源，這樣的思維轉換是必要的。", "word": "求められる" } ],
    [ { "text": "話雖如此，居民的共識形成需要時間，加上既得利益者放棄既有權益的抵抗根深蒂固，制度改革之路絕非平坦。", "word": "抵抗" } ]
  ],
