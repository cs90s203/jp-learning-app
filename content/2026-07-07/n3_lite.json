  "translations": [
    [ { "text": "從上個月開始，不搭電車通勤，改成騎自行車上班。", "word": "自転車通勤" } ],
    [ { "text": "一開始上坡很吃力很辛苦，但習慣之後意外地感覺不錯。", "word": "慣れる" } ],
    [ { "text": "一邊呼吸早晨的空氣一邊騎車，感覺頭腦變得清爽，工作也更容易集中。", "word": "集中する" } ],
    [ { "text": "運動不足好像也稍微改善了，身體也變輕盈了。", "word": "軽くなる" } ],
    [ { "text": "下雨天很困擾，但天氣好的日子騎自行車比較開心。", "word": "楽しい" } ],
    [ { "text": "對健康好像也不錯，打算暫時繼續下去。", "word": "続ける" } ]
