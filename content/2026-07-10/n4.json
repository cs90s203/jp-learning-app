  "translations": [
    [
      {
        "text": "上週六，和媽媽一起去了附近的煙火大會。",
        "word": "花火大会"
      }
    ],
    [
      {
        "text": "穿了浴衣，也在路邊攤吃了章魚燒，非常開心。",
        "word": "たこ焼き"
      }
    ],
    [
      {
        "text": "因為人非常多，找位子很辛苦，不過還是找到了一個很漂亮的位置坐下。",
        "word": "苦労する"
      }
    ],
    [
      {
        "text": "煙火的聲音非常大，好像連身體都在震動。",
        "word": "響く"
      }
    ],
    [
      {
        "text": "每當大煙火升起，媽媽都露出開心的表情。",
        "word": "嬉しい"
      }
    ],
    [
      {
        "text": "明年也想再一起去。",
        "word": "一緒に"
      }
    ]
  ]
