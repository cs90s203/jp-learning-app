  "translations": [
    [
      {
        "text": "上週末，第一次走進車站後面的一間二手唱片行。",
        "word": "中古レコード店"
      }
    ],
    [
      {
        "text": "店裡爵士樂和搖滾樂的唱片擺得滿滿的，光是看著就讓人興奮。",
        "word": "わくわくする"
      }
    ],
    [
      {
        "text": "瀏覽架子時，發現了以前喜歡的樂團的專輯，忍不住差點叫出聲來。",
        "word": "見つける"
      }
    ],
    [
      {
        "text": "價格也意外便宜，毫不猶豫就買了。",
        "word": "値段"
      }
    ],
    [
      {
        "text": "回家後馬上聽了一下，滿滿的懷念感湧上心頭。",
        "word": "懐かしい"
      }
    ],
    [
      {
        "text": "有時間的話，還想再去那家店看看。",
        "word": "覗く"
      }
    ]
  ]
}