    [
      { "text": "上週六，", "word": "土曜日" },
      { "text": "和朋友去了公園。", "word": "公園" }
    ],
    [
      { "text": "公園裡有很多人。", "word": "人" }
    ],
    [
      { "text": "孩子們正在跑步、玩耍。", "word": "子ども" }
    ],
    [
      { "text": "我們坐在長椅上", "word": "ベンチ" },
      { "text": "吃了便當。", "word": "お弁当" }
    ],
    [
      { "text": "天氣很好，", "word": "天気" },
      { "text": "風也很舒適。", "word": "風" }
    ],
    [
      { "text": "回家前，", "word": "帰る" },
      { "text": "在池塘旁拍了照片。", "word": "写真" }
    ],
    [
      { "text": "是非常快樂的一天。", "word": "楽しい" }
    ],
    [
      { "text": "我想下週也再去。", "word": "来週" }
