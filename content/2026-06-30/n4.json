  "translations": [
    [
      {
        "text": "從上個月開始去上烹飪課了。",
        "word": "料理"
      }
    ],
    [
      {
        "text": "明明很喜歡料理，",
        "word": "好き"
      },
      {
        "text": "卻做不好，",
        "word": "できる"
      },
      {
        "text": "所以決定去學。",
        "word": "習う"
      }
    ],
    [
      {
        "text": "老師非常親切，",
        "word": "親切"
      },
      {
        "text": "請她仔細教了我不懂的地方。",
        "word": "教える"
      }
    ],
    [
      {
        "text": "上週請她教了我馬鈴薯燉肉的做法。",
        "word": "肉じゃが"
      }
    ],
    [
      {
        "text": "切食材、用鍋燉煮",
        "word": "切る"
      },
      {
        "text": "比我想像的還要難。",
        "word": "難しい"
      }
    ],
    [
