  "translations": [
    [
      { "text": "最近使用社群媒體的人越來越多。", "word": "増える" }
    ],
    [
      { "text": "透過發照片或影片、", "word": "投稿する" },
      { "text": "和朋友交換訊息，", "word": "メッセージ" },
      { "text": "可以和遠方的人保持聯繫。", "word": "つながる" }
    ],
    [
      { "text": "然而，也有說法認為過度使用社群媒體", "word": "ところが" },
      { "text": "會對人際關係造成負面影響。", "word": "人間関係" }
    ],
    [
      { "text": "例如，會不自覺地把別人的貼文和自己的生活相比，", "word": "比べる" },
      { "text": "導致心情低落。", "word": "落ち込む" }
    ],
    [
      { "text": "另外，也有人說比起直接見面說話，", "word": "直接" },
      { "text": "文字往來增加了，", "word": "やり取り" },
      { "text": "反而更難傳達對方的心情。", "word": "伝わる" }
    ],
    [
      { "text": "社群媒體是方便的工具，", "word": "便利" },
      { "text": "但我認為用心思考使用方式很重要。", "word": "大切" }
    ]
  ],
