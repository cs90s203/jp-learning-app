  "translations": [
    [
      {
        "text": "近年，都市地區的人口集中持續增加，",
        "word": "集中"
      },
      {
        "text": "另一方面，對移居地方有興趣的人也越來越多。",
        "word": "移住"
      }
    ],
    [
      {
        "text": "都市交通方便，",
        "word": "交通"
      },
      {
        "text": "醫療和教育設施完善，",
        "word": "施設"
      },
      {
        "text": "但生活費高，住宅也大多狹窄。",
        "word": "生活費"
      }
    ],
    [
      {
        "text": "相對地，地方自然豐富，物價也便宜，",
        "word": "物価"
      },
      {
        "text": "有能過從容生活的優點。",
        "word": "ゆとり"
      }
    ],
    [
      {
        "text": "然而，就業機會有限，",
        "word": "雇用"
      },
      {
        "text": "在便利性方面不及都市也是事實。",
        "word": "利便性"
      }
    ],
    [
      {
        "text": "隨著遠端工作的普及，",
        "word": "テレワーク"
      },
      {
        "text": "在都市工作卻住在地方的「雙地區居住」生活方式也日益受到關注。",
        "word": "二地域居住"
      }
    ],
    [
      {
        "text": "哪種生活方式適合自己，",
        "word": "暮らし方"
      },
      {
        "text": "會因價值觀和生活環境而有所不同吧。",
        "word": "価値観"
      }
    ]
  ],
