  "translations": [
    [
      {
        "text": "上個月，我開始在區立圖書館做兒童說故事志工。",
        "word": "読み聞かせ"
      }
    ],
    [
      {
        "text": "原本以為自己不擅長在眾人面前說話，",
        "word": "苦手だ"
      },
      {
        "text": "但實際做了之後，發現比想像中更能樂在其中地持續下去。",
        "word": "楽しい"
      }
    ],
    [
      {
        "text": "有孩子會對我說「再讀一次」，",
        "word": "言ってくれる"
      },
      {
        "text": "每次聽到都讓我感到很有成就感。",
        "word": "やりがい"
      }
    ],
    [
      {
        "text": "選繪本也意外地很有學問，需要配合年齡下功夫調整內容。",
        "word": "工夫する"
      }
    ],
    [
      {
        "text": "雖然準備很花時間，也有聲音發不出來的日子，",
        "word": "かかる"
      },
      {
        "text": "但看到孩子們的笑容，疲勞也都忘了。",
        "word": "笑顔"
      }
    ],
    [
      {
        "text": "今後也想在不勉強的範圍內，長久地持續下去。",
        "word": "続けていく"
      }
    ]
  ]
}