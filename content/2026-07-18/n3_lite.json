  "translations": [
    [
      {
        "text": "上個月開始在陽台上開闢了一個小菜園。",
        "word": "菜園"
      }
    ],
    [
      {
        "text": "買了土回來，試著在花盆裡種下了小番茄和羅勒的種子。",
        "word": "植えてみる"
      }
    ],
    [
      {
        "text": "每天早上澆水已經成了習慣，發芽的時候真的很開心。",
        "word": "日課"
      }
    ],
    [
      {
        "text": "雖然常有蟲害或長不好而辛苦的時候，",
        "word": "苦労する"
      },
      {
        "text": "但看著它一點一點長大的樣子很開心。",
        "word": "楽しい"
      }
    ],
    [
      {
        "text": "如果能收成的話，打算做成沙拉來吃。",
        "word": "収穫できる"
      }
    ]
  ]
