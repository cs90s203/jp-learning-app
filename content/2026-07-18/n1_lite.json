  "translations": [
    [
      {
        "text": "近年，單身戶的增加正大幅改變著住宅市場的樣貌。",
        "word": "単身世帯"
      }
    ],
    [
      {
        "text": "過去以家庭為主的寬敞格局曾是主流，",
        "word": "間取り"
      },
      {
        "text": "但需求的重心已逐漸轉移到小巧的住宅單位。",
        "word": "移行してきた"
      }
    ],
    [
      {
        "text": "晚婚化、不婚化、高齡者獨居等因素複合交織，",
        "word": "絡み合い"
      },
      {
        "text": "據說單身戶如今已達到超過全體家庭三成的水準。",
        "word": "水準"
      }
    ],
    [
      {
        "text": "面對這樣的趨勢，各家開發商開始著手開發即使狹小也重視機能性的物件，",
        "word": "乗り出しており"
      },
      {
        "text": "試圖透過收納巧思與設備完善來吸引單身者的需求。",
        "word": "取り込もうとしている"
      }
    ],
    [
      {
        "text": "另一方面，單身高齡者的增加也凸顯出孤獨死與照護關懷體制不完善等社會課題，",
        "word": "浮き彫りにしており"
      },
      {
        "text": "住宅政策不僅需要居住品質，也需要考量如何確保與地區的連結這一視角。",
        "word": "つながり"
      }
    ]
  ]
}