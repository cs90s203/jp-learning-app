  "translations": [
    [
      {
        "text": "最近，職場的無紙化正急速推進。",
        "word": "ペーパーレス化"
      }
    ],
    [
      {
        "text": "會議資料變成全部用平板電腦分發，紙本文件幾乎看不到了。",
        "word": "配布される"
      }
    ],
    [
      {
        "text": "一開始對螢幕上難以閱讀感到困惑，",
        "word": "戸惑う"
      },
      {
        "text": "但漸漸習慣之後，搜尋功能很方便，能馬上找到需要的資訊。",
        "word": "検索機能"
      }
    ],
    [
      {
        "text": "聽說印刷和保管所花費的成本也大幅削減了。",
        "word": "削減できる"
      }
    ],
    [
      {
        "text": "另一方面，對於習慣邊手寫筆記邊整理想法的人來說，",
        "word": "手書き"
      },
      {
        "text": "似乎也有感到不順手的場合。",
        "word": "やりにくさ"
      }
    ],
    [
      {
        "text": "如何在便利性與易用性之間取得平衡，看來會成為今後的課題。",
        "word": "バランス"
      }
    ]
  ]
}