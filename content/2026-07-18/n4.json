  "translations": [
    [
      {
        "text": "上週日，我和妹妹在附近的公園野餐。",
        "word": "ピクニック"
      }
    ],
    [
      {
        "text": "因為天氣很好，大家看起來都很舒服。",
        "word": "気持ちよさそう"
      }
    ],
    [
      {
        "text": "我們吃便當、拍照，悠閒地度過了時間。",
        "word": "過ごす"
      }
    ],
    [
      {
        "text": "妹妹明明不擅長運動，卻很拼命地丟著飛盤。",
        "word": "苦手"
      }
    ],
    [
      {
        "text": "多虧如此，我也久違地活動了身體。",
        "word": "おかげで"
      }
    ],
    [
      {
        "text": "下個月也想再一起出門。",
        "word": "出かける"
      }
    ]
  ]
