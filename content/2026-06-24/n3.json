  "translations": [
    [
      {"text": "近年來，", "word": "近年"},
      {"text": "SNS已成為我們生活中不可或缺的東西。", "word": "欠かせない"}
    ],
    [
      {"text": "與朋友分享照片、", "word": "共有する"},
      {"text": "閱讀陌生人意見等，", "word": "読む"},
      {"text": "已成為日常之事。", "word": "日常的"}
    ],
    [
      {"text": "但是，我認為SNS不只有好的一面，", "word": "良い"},
      {"text": "也有問題點。", "word": "問題点"}
    ],
    [
      {"text": "例如，錯誤資訊容易擴散，", "word": "広がる"},
      {"text": "也有人因為與他人比較而消沉。", "word": "落ち込む"}
    ],
    [
      {"text": "然而，若善加利用，", "word": "使う"},
      {"text": "就能與遠方的家人朋友持續保持聯繫。", "word": "つながり続ける"}
    ],
    [
      {"text": "重要的不是擁有批判性看待資訊的眼光嗎？", "word": "持つ"}
