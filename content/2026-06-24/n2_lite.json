  "translations": [
    [
      {
        "text": "日本各地存在著許多擁有悠久歷史的傳統工藝。",
        "word": "伝統工芸"
      }
    ],
    [
      {
        "text": "陶藝、織品、漆器等，",
        "word": "陶芸"
      },
      {
        "text": "各地區紮根的技術傳承至今。",
        "word": "受け継ぐ"
      }
    ],
    [
      {
        "text": "但近年來，",
        "word": "近年"
      },
      {
        "text": "由於工匠高齡化和繼承人不足，",
        "word": "後継者"
      },
      {
        "text": "許多傳統工藝面臨存續危機。",
        "word": "危機"
      }
    ],
    [
      {
        "text": "針對這些問題，",
        "word": "問題"
      },
      {
        "text": "年輕世代嘗試學習傳統技術的趨勢也出現了。",
        "word": "学ぶ"
      }
    ],
    [
      {
        "text": "此外，透過線上販售傳統工藝品，",
        "word": "販売する"
      },
      {
        "text": "傳遞給國內外顧客的嘗試也備受矚目。",
        "word": "注目する"
      }
    ],
    [
      {
        "text": "傳統與革新如何兼顧，",
        "word": "両立する"
      },
      {
        "text": "正是當前所面對的考驗。",
        "word": "問う"
      }
    ]
  ],
