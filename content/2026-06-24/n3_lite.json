  "translations": [
    [
      {"text": "我每週三次", "word": "週"},
      {"text": "在附近的圖書館打工。", "word": "アルバイト"}
    ],
    [
      {"text": "主要工作是", "word": "主な"},
      {"text": "整理書籍和引導來館者。", "word": "案内"}
    ],
    [
      {"text": "一開始不太懂書的分類，", "word": "わかる"},
      {"text": "感到很困擾。", "word": "困る"}
    ],
    [
      {"text": "但是，", "word": null},
      {"text": "多虧前輩員工", "word": "先輩"},
      {"text": "細心地教我，", "word": "教える"},
      {"text": "漸漸熟悉了。", "word": "なれる"}
    ],
    [
      {"text": "因為圖書館有安靜沉穩的氛圍，", "word": "雰囲気"},
      {"text": "我非常喜歡。", "word": "好き"}
    ],
    [
      {"text": "看到讀者找到書後開心的樣子，", "word": "姿"},
      {"text": "就會感受到成就感。", "word": "感じる"}
    ]
  ],
