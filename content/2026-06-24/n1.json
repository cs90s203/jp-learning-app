  "translations": [
    [
      {
        "text": "資訊通訊技術的飛躍性發展，",
        "word": "発展"
      },
      {
        "text": "正從根本上為民主主義的存在方式帶來變革。",
        "word": "もたらす"
      }
    ],
    [
      {
        "text": "由於網路與社群媒體的普及，",
        "word": "普及"
      },
      {
        "text": "公民得以透過傳統代議制民主所未預設的形式，",
        "word": "想定する"
      },
      {
        "text": "參入政治言論空間。",
        "word": "参入する"
      }
    ],
    [
      {
        "text": "請願線上化、向行政機關電子表達意見等，",
        "word": "意見表明"
      },
      {
        "text": "直接民主主義要素的擴充值得肯定。",
        "word": "評価に値する"
      }
    ],
    [
      {
        "text": "然而，數位民主主義也潛藏結構性弱點。",
        "word": "脆弱性"
      }
    ],
    [
      {
        "text": "如過濾泡泡和迴聲室效應所象徵的，",
        "word": "象徴する"
      },
      {
        "text": "演算法對資訊的篩選，",
        "word": "選別"
      },
      {
        "text": "形成同質意見群體，",
        "word": "形成する"
      },
      {
        "text": "可能發揮促進社會兩極化的功能。",
        "word": "促進する"
      }
    ],
    [
      {
        "text": "此外，組織性假新聞的擴散和外國勢力干預選舉，",
        "word": "選挙介入"
      },
      {
        "text": "損害民主進程的風險也日益嚴峻。",
        "word": "深刻化する"
      }
    ],
    [
      {
        "text": "維持民主規範，需要同時並行地加強對科技企業的管制，",
        "word": "規制強化"
      },
      {
        "text": "並提升市民的媒體識讀能力，",
        "word": "メディアリテラシー"
      },
      {
        "text": "兩者皆非易事。",
        "word": "容易"
      }
    ],
    [
      {
        "text": "數位技術究竟有助於強化民主主義，",
        "word": "資する"
      },
      {
        "text": "還是侵蝕它，",
        "word": "侵食する"
      },
      {
        "text": "取決於整個社會如何主動面對。",
        "word": "向き合う"
      }
    ]
  ],
