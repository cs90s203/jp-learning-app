  "translations": [
    [
      {
        "text": "上個月，第一次在跳蚤市場擺攤看看。",
        "word": "出店する"
      }
    ],
    [
      {
        "text": "一大早就去佔位置，加上天氣也很好，真是幸運。",
        "word": "恵まれる"
      }
    ],
    [
      {
        "text": "把不再穿的衣服和雜貨擺出來，訂價格相當費工夫。",
        "word": "値段"
      }
    ],
    [
      {
        "text": "跟客人議價雖然讓人緊張，但比想像中還開心。",
        "word": "値段交渉"
      }
    ],
    [
      {
        "text": "雖然也有賣剩的東西，但半天就賣出不少，覺得很滿足。",
        "word": "満足する"
      }
    ],
    [
      {
        "text": "下次想多花點心思，連招牌和陳列都講究一下。",
