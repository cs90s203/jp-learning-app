    [
      {
        "text": "上週第一次去釣魚看看。",
        "word": "釣り"
      }
    ],
    [
      {
        "text": "早上有點早，雖然有點想睡，但還是努力準備了。",
        "word": "準備する"
      }
    ],
    [
      {
        "text": "朋友約我，一起往河邊出發了。",
        "word": "誘う"
      }
    ],
    [
      {
        "text": "魚怎麼也釣不到，有點辛苦。",
        "word": "釣れる"
      }
    ],
    [
      {
        "text": "不過最後釣到一隻，非常開心。",
        "word": "嬉しい"
      }
    ],
    [
      {
        "text": "下次想釣更大的魚。",
