  "translations": [
    [ { "text": "近代國家的行政組織，為了實現有效率的業務執行，發展出了官僚制這種機制。", "word": "官僚制" } ],
    [ { "text": "明確的權限分工與依循規則的手續，具有排除恣意判斷、確保公平性的重大意義。", "word": "公平性" } ],
    [ { "text": "然而，這樣的特徵同時也潛藏著導致組織僵化這種副作用的危險性。", "word": "硬直化" } ],
    [ { "text": "由於過度貫徹先例主義，面對新的課題往往無法靈活應對，結果不少情況被社會的變化拋在後面。", "word": "前例主義" } ],
    [ { "text": "尤其各自為政的行政弊端經常被人指出：由於各部會過度堅持自身的管轄範圍，跨部門政策課題的應對陷入被動的案例層出不窮。", "word": "縦割り行政" } ],
    [ { "text": "為了突破這種局面，近年來推動數位化、設置跨部門專案團隊等改革正被嘗試推行。", "word": "デジタル化" } ],
    [ { "text": "不過也有根深蒂固的看法指出，光是改變制度無法從根本解決問題，組織文化本身的變革才是不可或缺的。", "word": "組織文化" } ],
    [ { "text": "可以說，行政改革真正的成敗不僅在於規則的重新檢視，更取決於能否改變每一位職員的意識。", "word": "行政改革" } ]
  ],
