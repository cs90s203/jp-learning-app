  "translations": [
    [ { "text": "上週日，因為弟弟有鋼琴發表會，所以全家人一起去看了。", "word": "発表会" } ],
    [ { "text": "弟弟雖然很緊張，但能夠不出錯地彈到最後，真的很厲害。", "word": "できる" } ],
    [ { "text": "演奏結束後，大家又是拍手又是拍照，一起開心慶祝。", "word": "喜ぶ" } ],
    [ { "text": "弟弟笑著說「雖然累，但很開心」。", "word": "楽しい" } ],
    [ { "text": "他說下次想挑戰更難的曲子。", "word": "挑戦する" } ]
  ],
