  "translations": [
    [ { "text": "這幾年，使用外送服務的人急速增加。", "word": "増加する" } ],
    [ { "text": "以前只能在外食和自己煮之間二選一，現在只要一支手機，就能請人把喜歡的店的料理送到家。", "word": "届ける" } ],
    [ { "text": "對獨居年輕人或忙碌的雙薪家庭來說，這種便利性想必是很大的魅力。", "word": "便利さ" } ],
    [ { "text": "另一方面，也有人指出外送員的勞動環境，以及過度包裝造成垃圾增加等課題。", "word": "指摘する" } ],
    [ { "text": "在享受便利的同時，是不是也該關注這些問題呢？", "word": "享受する" } ],
    [ { "text": "隨著技術的進步，我們的飲食生活今後或許還會持續改變。", "word": "進歩" } ]
