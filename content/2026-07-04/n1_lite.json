  "translations": [
    [ { "text": "在全國人口持續減少之下，空屋增加已成為嚴重的社會問題。", "word": "空き家" } ],
    [ { "text": "根據總務省的調查，空屋率逐年上升，遭放任不管的建築物恐怕會招致倒塌危險或治安惡化。", "word": "招く" } ],
    [ { "text": "面對這樣的情況，部分地方自治體開始嘗試整修空屋，將其活用為移居者的住所或地區交流的據點。", "word": "改修する" } ],
    [ { "text": "特別是在地方城市，透過空屋銀行制度，將都市地區的移居希望者與物件配對的做法也逐漸普及。", "word": "空き家バンク制度" } ],
    [ { "text": "可以說，這不是單純的拆除或放任，而是需要轉向重新利用既有資源的思維。", "word": "転換" } ],
    [ { "text": "不過，整修需要高額費用，加上有不少案例難以確定所有人，因此制度面的支援擴充可說是當務之急。", "word": "急務" } ]
  ],
