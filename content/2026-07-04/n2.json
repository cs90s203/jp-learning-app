  "translations": [
    [ { "text": "近年，「心理安全感」這個概念在組織建構上愈發受到重視。", "word": "心理的安全性" } ],
    [ { "text": "這指的是成員即使坦率地說出自己的意見或疑問，也不用擔心會被責罰或評價下降的狀態。", "word": "発言する" } ],
    [ { "text": "在心理安全感低的職場中，即使察覺到失誤也會猶豫要不要報告，結果往往等問題擴大後才被發現。", "word": "ためらう" } ],
    [ { "text": "另一方面，在心理安全感較高的職場中，容易產生熱烈的討論，新點子也會接連被提出。", "word": "議論" } ],
    [ { "text": "不過，心理安全感並不單純意味著舒適，而是應該注意，它其實是以歡迎健全衝突與坦率回饋的文化為前提的。", "word": "歓迎する" } ]
