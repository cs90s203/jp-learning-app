  "translations": [
    [ { "text": "在勞動市場中，比起能力與經驗，年齡被重視為錄用或升遷判斷基準的情況依然不少。", "word": "重視される" } ],
    [ { "text": "儘管法律禁止在徵才啟事上明列年齡限制，實際的選拔過程中，一定年齡以上的應徵者被默默排除在外的案例卻層出不窮。", "word": "排除される" } ],
    [ { "text": "背景中，有人指出企業方存在一種成見，認為年輕人較有彈性，也能壓低教育成本。", "word": "思い込み" } ],
    [ { "text": "然而，這種以年齡為依據的篩選，將擁有豐富經驗與專業知識的人才排除在組織之外，也可說是在勞動人口逐漸減少的社會中，自行縮小了善用人才的機會。", "word": "人材活用" } ],
    [ { "text": "此外，中高齡世代再就業困難，會助長經濟上的不穩定，甚至可能導致消費活動停滯。", "word": "助長する" } ],
    [ { "text": "今後，企業應被要求不拘泥於年齡這種表面指標，建立能適當評估個人能力的機制。", "word": "構築する" } ]
