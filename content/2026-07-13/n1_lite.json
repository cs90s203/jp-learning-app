  "translations": [
    [ { "text": "SNS融入日常生活已久，但隨著使用時間增加，其對年輕人心理健康的影響開始受到指出。", "word": "指摘される" } ],
    [ { "text": "不少年輕人會將他人的貼文與自己比較，因而產生自卑感與焦慮。", "word": "比較する" } ],
    [ { "text": "事實上，也有報告指出，每次看到貼文就情緒低落而尋求諮詢的年輕人數量逐年增加。", "word": "相談件数" } ],
    [ { "text": "尤其對「讚」的數量患得患失的傾向，可能使自我肯定感變得不穩定。", "word": "自己肯定感" } ],
    [ { "text": "據專家表示，比起SNS的使用時間本身，被動持續觀看他人生活更容易造成心理負擔。", "word": "心理的負担" } ],
    [ { "text": "SNS本身並非壞事，也有不少人指出，效果好壞取決於使用方式。", "word": "指摘" } ],
    [ { "text": "有意識地限制使用時間、關閉通知等，如何巧妙保持與SNS的距離，是目前所需要的用心。", "word": "工夫" } ]
  ]
}
