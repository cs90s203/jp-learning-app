  "translations": [
    [ { "text": "上個月，我和姊姊爬了附近的山。", "word": "登る" } ],
    [ { "text": "因為天氣很好，從山頂看到的景色非常漂亮。", "word": "景色" } ],
    [ { "text": "途中雖然又累又休息，但能走到最後很開心。", "word": "ことができる" } ],
    [ { "text": "在山頂邊吃飯糰，邊和姊姊聊了各種話題。", "word": "食べる" } ],
    [ { "text": "雖然很累，但很有成就感，成為了難忘的一天。", "word": "達成感" } ],
    [ { "text": "下次也想挑戰看看不同的山。", "word": "挑戦する" } ]
