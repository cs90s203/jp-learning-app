  "translations": [
    [ { "text": "在高齡化持續發展之中，能熟練使用智慧型手機與網路的高齡者，與不擅長使用的族群之間所產生的「數位落差」，已成為備受關注的社會課題。", "word": "デジタルデバイド" } ],
    [ { "text": "隨著行政手續線上化、無現金支付日益普及，不熟悉數位設備的高齡者在日常生活中感到不便的情況似乎也逐漸增多。", "word": "不便" } ],
    [ { "text": "面對這樣的狀況，地方政府與地區志工團體開設教導智慧型手機使用方法的講座，支援的圈子正逐漸擴大。", "word": "支援" } ],
    [ { "text": "這不僅是單純教導操作方法，透過面對面的交流也能達到防止孤立的效果，因此數位教育的重要性預料將日益增加。", "word": "重要性" } ]
  ]
