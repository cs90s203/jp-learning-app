  "translations": [
    [ { "text": "最近，我在陽台開始種了小小的家庭菜園。", "word": "家庭菜園" } ],
    [ { "text": "買了番茄和羅勒的幼苗，試著種進花盆裡。", "word": "苗" } ],
    [ { "text": "只要澆水就意外地容易生長，早上看到綠色的葉子心情就很好。", "word": "育つ" } ],
    [ { "text": "每天檢查有沒有長蟲，其實也是件蠻有趣的工作。", "word": "虫" } ],
    [ { "text": "雖然還沒結果，但看著它一點一點長大很讓人期待。", "word": "楽しみ" } ],
    [ { "text": "下次夏天也想試著種小黃瓜和青椒。", "word": "育てる" } ]
