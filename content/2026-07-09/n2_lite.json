  "translations": [
    [ { "text": "近年電子書迅速普及，許多人的閱讀習慣正在改變。", "word": "電子書籍" } ],
    [ { "text": "不需要隨身攜帶紙本書，能把好幾百本書裝進一台裝置的這一點受到支持。", "word": "端末" } ],
    [ { "text": "另一方面，也有人惋惜翻紙頁的感覺和把書排在書架上的樂趣正在消失。", "word": "本棚" } ],
    [ { "text": "因為可以自由調整文字大小，對高齡者來說容易閱讀這項優點也不容忽視。", "word": "高齢者" } ],
    [ { "text": "此外，購買後能立即開始閱讀的便利性，也可說是電子書獨有的魅力。", "word": "魅力" } ],
    [ { "text": "今後，電子書與紙本書或許能各自發揮優點，共存下去。", "word": "共存する" } ]
