  "translations": [
    [ { "text": "最近迷上了逛二手書店。", "word": "古本屋巡り" } ],
    [ { "text": "契機是在車站前一間小小的二手書店，偶然找到的一本舊小說。", "word": "古本屋" } ],
    [ { "text": "那種新書沒有的獨特氣味，以及前任持有者寫下的筆記，不知為何吸引了我的心。", "word": "惹かれる" } ],
    [ { "text": "假日時，我會逛好幾間二手書店，尋找挖到寶的樂趣成了期待的事。", "word": "掘り出し物" } ],
    [ { "text": "因為價格也便宜，可以輕鬆嘗試各種類型，這點也很棒。", "word": "挑戦する" } ],
    [ { "text": "有時也會和店主聊書聊得很起勁，這也是逛二手書店的醍醐味。", "word": "醍醐味" } ],
    [ { "text": "現在房間的書架已經被二手書塞得滿滿的了。", "word": "本棚" } ]
  ],
