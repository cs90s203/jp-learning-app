  "translations": [
    [ { "text": "上週日，我和爸爸去附近的河邊釣魚。", "word": "釣り" } ],
    [ { "text": "一大早起床，兩人一起做便當、準備工具。", "word": "お弁当" } ],
    [ { "text": "到了河邊後，發現魚比想像中多，爸爸釣到了三條。", "word": "釣る" } ],
    [ { "text": "我試了好幾次，結果一條也沒釣到。", "word": "釣れる" } ],
    [ { "text": "即使如此，和爸爸邊聊天邊度過的時光非常開心，成了美好的回憶。", "word": "思い出" } ],
    [ { "text": "下次還想再一起去。", "word": "一緒に" } ]
  ],
