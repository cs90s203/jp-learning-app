  "translations": [
    [ { "text": "在圍繞氣候變遷對策的討論中，經常成為爭議焦點的是世代間的公平性。", "word": "公平性" } ],
    [ { "text": "目前的政策決策主要由現役世代所主導，但其影響將由未來世代在更長的時間裡承受。", "word": "将来世代" } ],
    [ { "text": "溫室氣體排放削減若一再拖延，下一代必須承擔的環境與經濟成本就會不斷增加。", "word": "温室効果ガス" } ],
    [ { "text": "為了矯正這種結構性的不對稱，部分國家正在檢討將年輕人意見反映到政策制定的機制，以及設置代表未來世代利益發聲的獨立機構。", "word": "独立機関" } ],
    [ { "text": "不過，現行的民主主義制度基本上是反映當前有權者意向的機制，對於尚未擁有選舉權、甚至尚未出生的世代的利害關係該如何納入制度，至今仍未找到明確的答案。", "word": "民主主義制度" } ],
    [ { "text": "今後，如何超越短期的政治利害，建構立足於長期視野的共識形成框架，將成為被追問的課題。", "word": "合意形成" } ]
  ],
