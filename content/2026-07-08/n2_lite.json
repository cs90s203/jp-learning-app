  "translations": [
    [ { "text": "遠距辦公變得普及之後，如何整備自家的工作環境變得越來越重要。", "word": "作業環境" } ],
    [ { "text": "據說把書桌和椅子的高度配合身體調整，就算長時間工作也不容易疲累。", "word": "合わせる" } ],
    [ { "text": "此外，只要調整螢幕位置符合視線高度、或調整照明，集中力就會大幅改變。", "word": "集中力" } ],
    [ { "text": "網路環境也是需要重新審視的地方，無法確保穩定的Wi-Fi時，會議中影像停頓等問題容易發生。", "word": "通信環境" } ],
    [ { "text": "甚至有人為了區分工作與休息，刻意將書桌放在窗邊。", "word": "あえて" } ],
    [ { "text": "找到適合自己的環境，應該能提升生產力。", "word": "生産性" } ]
