  "translations": [
    [ { "text": "日本率先全球進入「超高齡社會」，正面臨65歲以上人口占總人口近30%的現實。", "word": "超高齢社会" } ],
    [ { "text": "高齡化的推進帶來了社會保障費的增加，年金・醫療・照護各領域的財政可持續性成為嚴重的課題。", "word": "持続性" } ],
    [ { "text": "對此，政府採取了透過宏觀經濟滑動調整抑制年金給付、提高醫療費自費比例等措施，但效果有限，也有根深蒂固的批評認為尚未找到根本性的財源確保方案。", "word": "措置" } ],
    [ { "text": "另一方面，透過科技活用減輕照護負擔，以及高齡者自身繼續就業・參與社會、轉為「支撐的一方」的想法也備受矚目。", "word": "発想" } ],
    [ { "text": "但若沒有制度性的支援，這些新做法得以發揮作用的環境難以整備。", "word": "アプローチ" } ],
    [ { "text": "超高齡社會中維持福祉，不只是財政問題，更連結到社會在何種價值觀下支撐其成員這一根本性問題。", "word": "価値観" } ]
  ],
