  "translations": [
    [
      {
        "text": "近幾年，",
        "word": "数年"
      },
      {
        "text": "在家工作的",
        "word": "仕事"
      },
      {
        "text": "遠端工作",
        "word": "リモートワーク"
      },
      {
        "text": "迅速普及了。",
        "word": "広がる"
      }
    ],
    [
      {
        "text": "通勤時間消失，",
        "word": "通勤"
      },
      {
        "text": "變得能按自己的步調工作，",
        "word": "働く"
      },
      {
        "text": "有這種感覺的人很多。",
        "word": "多い"
      }
    ],
    [
      {
        "text": "然而，",
        "word": "しかし"
      },
      {
        "text": "也有人認為並非全是好事",
        "word": "よい"
      },
      {
        "text": "這樣的意見。",
        "word": "意見"
      }
    ],
    [
      {
        "text": "因為有家人在就難以集中，",
        "word": "集中"
      },
      {
        "text": "工作和生活的界線",
        "word": "境目"
      },
      {
        "text": "也會變得模糊。",
        "word": "あいまい"
      }
    ],
    [
      {
        "text": "然而最近，",
        "word": "ところが"
      },
      {
        "text": "利用附近的咖啡廳或共享辦公室",
        "word": "カフェ"
      },
      {
        "text": "的人也增加了。",
        "word": "増える"
      }
    ],
    [
      {
        "text": "由於變得能選擇地點，",
        "word": "場所"
      },
      {
        "text": "反而",
        "word": "かえって"
      },
      {
        "text": "有人說生產力提高了。",
        "word": "生産性"
      }
    ],
    [
      {
        "text": "今後的工作方式，",
        "word": "働き方"
      },
      {
        "text": "並非只有一個正確答案，",
        "word": "正解"
      },
      {
        "text": "而會變成適合每個人的形式吧，",
        "word": "形"
      },
      {
