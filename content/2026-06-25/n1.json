  "translations": [
    [
      {
        "text": "據說世界上存在著數千種語言，",
        "word": "言語"
      },
      {
        "text": "但其中許多",
        "word": "多く"
      },
      {
        "text": "正瀕臨消滅的危機。",
        "word": "危機"
      }
    ],
    [
      {
        "text": "根據某項統計，",
        "word": "統計"
      },
      {
        "text": "在本世紀末前",
        "word": "末"
      },
      {
        "text": "現存語言的半數",
        "word": "半数"
      },
      {
        "text": "甚至有可能會消失。",
        "word": "失う"
      }
    ],
    [
      {
        "text": "語言並非單純的",
        "word": "言語"
      },
      {
        "text": "溝通工具。",
        "word": "道具"
      }
    ],
    [
      {
        "text": "每一種語言中，",
        "word": "言語"
      },
      {
        "text": "都交織著那片土地孕育出的",
        "word": "育む"
      },
      {
        "text": "世界觀與價值觀，",
        "word": "世界観"
      },
      {
        "text": "以及歷經漫長歲月累積的智慧。",
        "word": "知恵"
      }
    ],
    [
      {
        "text": "一種語言的消失，",
        "word": "言語"
      },
      {
        "text": "意味著對全人類而言",
        "word": "人類"
      },
      {
        "text": "無可替代的財產",
        "word": "財産"
      },
      {
        "text": "將永遠失去。",
        "word": "失う"
      }
    ],
    [
      {
        "text": "當然，",
        "word": "むろん"
      },
      {
        "text": "語言的興衰是歷史的必然，",
        "word": "盛衰"
      },
      {
        "text": "要保存一切並不現實，",
        "word": "保存"
      },
      {
        "text": "也會有這樣的看法吧。",
        "word": "見方"
      }
    ],
    [
      {
        "text": "然而，",
        "word": "しかしながら"
      },
      {
        "text": "整備讓使用者能懷著自豪傳承母語的環境，",
        "word": "受け継ぐ"
      },
      {
        "text": "在守護文化多樣性上",
        "word": "多様性"
      },
      {
        "text": "是絕不可輕視的課題。",
        "word": "課題"
      }
    ],
    [
      {
        "text": "正因為在全球化加速的此刻，",
        "word": "加速"
      },
      {
        "text": "我們",
        "word": "私たち"
      },
      {
        "text": "難道不需要重新審視腳邊語言的分量嗎。",
        "word": "問い直す"
      }
    ]
  ],
  "difficulty": {
    "target_vocab_rate": 0.16,
    "jlpt_level": "N1"
  }
