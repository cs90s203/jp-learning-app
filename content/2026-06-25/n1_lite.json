  "translations": [
    [
      {
        "text": "隨著都市化的推進，",
        "word": "都市化"
      },
      {
        "text": "綠色空間所帶來的",
        "word": "空間"
      },
      {
        "text": "恩惠重新受到關注。",
        "word": "恩恵"
      }
    ],
    [
      {
        "text": "在高樓林立的街道中，",
        "word": "街"
      },
      {
        "text": "公園與行道樹不僅帶來些許滋潤，",
        "word": "潤い"
      },
      {
        "text": "也肩負緩和氣溫上升的",
        "word": "上昇"
      },
      {
        "text": "作用。",
        "word": "役割"
      }
    ],
    [
      {
        "text": "根據近年的研究，",
        "word": "研究"
      },
      {
        "text": "居住在綠意豐富地區的人們，",
        "word": "暮らす"
      },
      {
        "text": "精神壓力較少，",
        "word": "ストレス"
      },
      {
        "text": "健康狀態也相對良好。",
        "word": "良好"
      }
    ],
    [
      {
        "text": "此外，",
        "word": "また"
      },
      {
        "text": "綠地也作為人與人自然交流的場所",
        "word": "場"
      },
      {
        "text": "發揮作用，",
        "word": "機能"
      },
      {
        "text": "被期待具有加深地區連結的效果。",
        "word": "結びつき"
      }
    ],
    [
      {
        "text": "再者，街道與公園的綠意不僅美化景觀，",
        "word": "景観"
      },
      {
        "text": "也能撫慰造訪者的心，",
        "word": "和ませる"
      },
      {
        "text": "這份效果同樣不容忽視。",
        "word": "見逃す"
      }
    ],
    [
      {
        "text": "另一方面，",
        "word": "一方"
      },
      {
        "text": "在有限的土地中",
        "word": "土地"
      },
      {
        "text": "確保綠地",
        "word": "確保"
      },
      {
        "text": "並不容易。",
        "word": "容易"
      }
    ],
    [
      {
        "text": "今後，",
        "word": "今後"
      },
      {
        "text": "活用屋頂與牆面等，",
        "word": "活用"
      },
      {
        "text": "重新審視都市結構本身的",
        "word": "構造"
      },
      {
        "text": "發想將不可或缺吧。",
        "word": "発想"
      }
    ]
  ],
