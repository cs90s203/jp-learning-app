  "translations": [
    [
      {
        "text": "聽說最近",
        "word": "最近"
      },
      {
        "text": "不搭電車、",
        "word": "電車"
      },
      {
        "text": "改騎腳踏車",
        "word": "自転車"
      },
      {
        "text": "通勤的人增加了。",
        "word": "増える"
      }
    ],
    [
      {
        "text": "我的同事也",
        "word": "同僚"
      },
      {
        "text": "從上個月",
        "word": "先月"
      },
      {
        "text": "改騎了腳踏車。",
        "word": "変える"
      }
    ],
    [
      {
        "text": "問了理由，",
        "word": "聞く"
      },
      {
        "text": "據說是因為既能運動，",
        "word": "運動"
      },
      {
        "text": "又能避開電車的擁擠。",
        "word": "避ける"
      }
    ],
    [
      {
        "text": "的確，",
        "word": "たしかに"
      },
      {
        "text": "因為每天早上不用趕固定時間",
        "word": "毎朝"
      },
      {
        "text": "跑去車站，",
        "word": "走る"
      },
      {
        "text": "心情變得從容。",
        "word": "余裕"
      }
    ],
    [
      {
        "text": "不過，他說",
        "word": "ただし"
      },
      {
        "text": "下雨天",
        "word": "雨"
      },
      {
        "text": "很辛苦。",
        "word": "大変"
      }
    ],
    [
      {
        "text": "即使如此，",
        "word": "それでも"
      },
      {
        "text": "據說為了健康",
        "word": "健康"
      },
