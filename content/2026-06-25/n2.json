  "translations": [
    [
      {
        "text": "日本是世界上",
        "word": "日本"
      },
      {
        "text": "高齡化最為嚴重的",
        "word": "高齢化"
      },
      {
        "text": "國家之一。",
        "word": "国"
      }
    ],
    [
      {
        "text": "高齡者占總人口的比例",
        "word": "割合"
      },
      {
        "text": "逐年上升，",
        "word": "上昇"
      },
      {
        "text": "對社會型態本身",
        "word": "あり方"
      },
      {
        "text": "帶來巨大影響。",
