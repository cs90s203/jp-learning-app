      }
    ],
    [
      {
        "text": "另一方面，",
        "word": "一方"
      },
      {
        "text": "由於醫療的發展，",
        "word": "発展"
      },
      {
        "text": "能精神地持續活動的高齡者",
        "word": "続ける"
      },
      {
        "text": "也增加了。",
        "word": "増える"
      }
    ],
    [
      {
        "text": "他們豐富的經驗與知識，",
        "word": "経験"
      },
      {
        "text": "對地區社會而言",
        "word": "地域"
      },
      {
        "text": "可說是寶貴的財產。",
        "word": "財産"
      }
    ],
    [
      {
        "text": "因此，",
        "word": "したがって"
      },
      {
        "text": "今後不應以年齡劃分人，",
        "word": "区切る"
      },
      {
        "text": "而是建立人人都能發揮能力的機制",
        "word": "仕組み"
      },
      {
        "text": "受到要求。",
        "word": "求める"
      }
    ],
    [
      {
        "text": "例如，",
        "word": "たとえば"
      },
      {
        "text": "退休後仍能持續工作的制度，",
        "word": "制度"
      },
      {
