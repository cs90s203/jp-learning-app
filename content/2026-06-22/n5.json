  "particles": {
    "と": "表示「和/與」，連接同行的人物（例：お母さんと＝和媽媽）",
    "へ": "表示移動的方向，「往...去」（例：スーパーへ行く＝去超市）",
    "は": "表示句子的主題，相當於「說到...」",
    "を": "表示動詞動作的直接對象（受詞）",
    "や": "表示非窮舉的列舉，「...啦...啦」（例：野菜や肉や魚＝蔬菜啦肉啦魚啦）",
    "で": "表示動作發生的場所（例：レジで＝在收銀台）",
    "から": "表示起點「從...」，或接て形後表示「...之後」",
    "に": "表示動作的目的地或歸著點（例：家に帰る＝回家）",
    "て": "動詞て形，連接兩個動作或狀態；接形容詞表示原因/並列",
    "ます": "丁寧語助動詞，表示禮貌語氣",
    "た": "助動詞，表示過去式或完成"
  },
