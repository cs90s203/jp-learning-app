  "translations": [
    [
      {
        "text": "上週六，和朋友一起參加了一直很感興趣的陶藝教室。",
        "word": "陶芸"
      }
    ],
    [
      {
        "text": "碰黏土是小時候以來的第一次，一開始怎麼想都做不出理想的形狀。",
        "word": "粘土"
      }
    ],
    [
      {
        "text": "請老師教了手的動作和施力的方式等訣竅之後，漸漸地變得熟練起來。",
        "word": "コツ"
      }
    ],
    [
      {
        "text": "花了兩個小時，最後完成了只屬於自己的碗，很有成就感。",
        "word": "達成感"
      }
    ],
    [
      {
        "text": "聽說要一個月後才能燒製完成，所以很期待成品。",
        "word": "楽しみだ"
      }
    ],
    [
      {
        "text": "如果有時間的話，還想再去上課。",
        "word": "通う"
      }
    ]
  ]
}