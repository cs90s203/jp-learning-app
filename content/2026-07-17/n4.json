  "translations": [
    [
      {
        "text": "上個月，久違地和爸爸去河邊釣魚了。",
        "word": "釣り"
      }
    ],
    [
      {
        "text": "又是一大早起床，又是準備工具，久違地忙碌了一番。",
        "word": "忙しい"
      }
    ],
    [
      {
        "text": "因為河水很冰冷，所以一開始遲遲釣不到魚。",
        "word": "冷たい"
      }
    ],
    [
      {
        "text": "即使如此，爸爸還是不放棄地持續挑戰，最後終於釣到了一條大魚。",
        "word": "釣る"
      }
    ],
    [
      {
        "text": "用那條魚又是做晚餐、又是拍照，成了美好的回憶。",
        "word": "思い出"
      }
    ]
  ]
