  "translations": [
    [ { "text": "隨著訪日外國觀光客的增加，車站與觀光景點的指引標示改善已成為當務之急。", "word": "急務" } ],
    [ { "text": "以往的標示多半僅止於日語與英語並列，難以說已充分因應多語言需求。", "word": "併記" } ],
    [ { "text": "因此近年來，越來越多地方自治體導入活用圖標與QR碼、能立即連上多語言語音導覽的機制。", "word": "導入する" } ],
    [ { "text": "不過，各地區的建置狀況參差不齊，也有不少自治體因財政限制而因應進度落後。", "word": "ばらつき" } ],
    [ { "text": "此外，不僅僅是增加語言種類，考量文化背景差異的表達巧思也是必要的。", "word": "工夫" } ],
    [ { "text": "今後期望國家與地方自治體能攜手合作，制定出統一的指引方針。", "word": "策定する" } ]
  ]
