  "translations": [
    [ { "text": "上星期六，我和姊姊一起去了附近的煙火大會。", "word": "花火大会" } ],
    [ { "text": "因為人非常多，所以提早佔了位子。", "word": "ので" } ],
    [ { "text": "在攤販吃了炒麵、買了蘋果糖葫蘆，享受祭典的氣氛。", "word": "屋台" } ],
    [ { "text": "煙火一開始，天空就伴隨著巨大聲響染上了五顏六色。", "word": "輝く" } ],
    [ { "text": "姊姊明明喜歡拍照，那天卻忘了帶手機，看起來有點可惜。", "word": "好き" } ],
    [ { "text": "即使如此，我們兩人還是能悠閒地看完煙火，成了非常美好的回憶。", "word": "思い出" } ]
