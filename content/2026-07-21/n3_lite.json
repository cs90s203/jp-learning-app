  "translations": [
    [ { "text": "上個月，我第一次去了在當地舉辦的早市。", "word": "朝市" } ],
    [ { "text": "新鮮的蔬菜和魚都賣得很便宜，附近的居民擠得熱鬧非凡。", "word": "賑わう" } ],
    [ { "text": "我和一位賣著「自家剛採收」蔬菜的奶奶聊了一下，她甚至教我怎麼種。", "word": "育て方" } ],
