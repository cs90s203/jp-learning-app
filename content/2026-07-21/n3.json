  "translations": [
    [ { "text": "半年前開始，我養成了拍下每天的料理來記錄的「料理日記」習慣。", "word": "料理日記" } ],
    [ { "text": "契機是在電視上看到一個說「飲食記錄有助於健康管理」的節目。", "word": "きっかけ" } ],
    [ { "text": "一開始有時候會覺得麻煩，但持續下來後漸漸注意到自己飲食生活的習慣。", "word": "気づく" } ],
    [ { "text": "我發現自己蔬菜攝取不足的日子持續著，也常常做同樣的菜。", "word": "続く" } ],
    [ { "text": "多虧如此，買東西時會有意識地挑選蔬菜，也開始嘗試新食譜。", "word": "意識する" } ],
    [ { "text": "雖然只是個小習慣，卻感覺整體生活正一點一點地改變著。", "word": "変わる" } ]
