  "translations": [
    [ { "text": "智慧型手機和網路滲透到生活的各個角落，但另一方面，對操作感到不安的銀髮族世代也不在少數。", "word": "シニア世代" } ],
    [ { "text": "因應這樣的狀況，各地的公民會館和圖書館掀起了開設銀髮族數位課程的風潮。", "word": "デジタル講座" } ],
    [ { "text": "課程中不僅教應用程式的使用方法，也仔細教導辨別詐騙郵件等安全對策。", "word": "見分け方" } ],
    [ { "text": "據說參加者反映「能和孫子視訊通話了」「公家機關的手續能在線上辦理，幫了大忙」等意見。", "word": "ビデオ通話" } ],
    [ { "text": "因此，這些課程不只是單純教技術，也被期待扮演提升生活品質的支援角色。", "word": "支援" } ],
    [ { "text": "話雖如此，課程數量因地區而有差異，如何打造人人都能平等學習的環境，將是今後的課題。", "word": "環境づくり" } ]
  ]
}
