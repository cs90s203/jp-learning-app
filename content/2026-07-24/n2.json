  "translations": [
    [ { "text": "近年，以都市地區為中心，利用陽台或屋頂的家庭菜園悄悄形成了一股熱潮。", "word": "家庭菜園" } ],
    [ { "text": "背景可能是待在家時間增加帶來的生活方式改變，以及對飲食安全的關注升高。", "word": "背景" } ],
    [ { "text": "實際自己種植蔬菜後，不僅能近距離觀察成長過程，與家人一起品嚐收穫的蔬菜，也讓不少人表示對飲食的意識本身產生了變化。", "word": "意識" } ],
    [ { "text": "不過，都市地區有限的空間難以確保充足的日照，不少人為蔬菜長不如預期而煩惱。", "word": "悩み" } ],
    [ { "text": "即便如此，地方自治團體主辦的栽培講座、以及能與有經驗者交換資訊的線上社群日漸充實，初學者也能輕鬆挑戰的環境正逐漸完善。", "word": "環境" } ]
  ]
}
