  "translations": [
    [ { "text": "上週六，我和妹妹去了附近神社舉辦的夏日祭典。", "word": "夏祭り" } ],
    [ { "text": "穿著浴衣，在攤販買了章魚燒和刨冰，還玩了撈金魚，玩得很開心。", "word": "楽しむ" } ],
    [ { "text": "人很多，差點走散，所以我緊緊握著妹妹的手。", "word": "はぐれる" } ],
    [ { "text": "最後煙火升起，兩人一邊抬頭看著夜空，一邊約定明年還要一起來。", "word": "約束する" } ],
    [ { "text": "真是非常開心的一天。", "word": "楽しい" } ]
