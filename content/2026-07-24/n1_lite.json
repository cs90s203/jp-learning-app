    [ { "text": "因新冠疫情而急速普及的遠距工作，不僅改變了工作方式，也逐漸對人們居住地的選擇帶來重大影響。", "word": "リモートワーク" } ],
    [ { "text": "以往人們理所當然地重視通勤便利性而選擇住在都市地區，但隨著能在線上完成工作的職種增加，遷移據點到自然環境豐富地方的人正逐漸增加。", "word": "移す" } ],
    [ { "text": "地方政府也為了推動這股潮流，推出了針對移居者的住宅補助、提供與地區社群交流的機會等各種政策措施。", "word": "施策" } ],
    [ { "text": "不過，地方地區醫療機構和教育設施不如都市地區充實的情況也不少，考慮移居時，有必要以長期的觀點判斷生活基礎是否穩固。", "word": "見極める" } ],
    [ { "text": "這股動向究竟只是一時的流行，還是會作為整體社會結構性變化而扎根下去，今後的發展值得關注。", "word": "注目する" } ]
  ]
}
