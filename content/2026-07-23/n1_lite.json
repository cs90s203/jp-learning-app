  "translations": [
    [ { "text": "在日本，隨著少子高齡化帶來的勞動力短缺，外籍勞工的引進逐年擴大。", "word": "外国人労働者" } ],
    [ { "text": "政府雖然一直在推動居留資格的擴充與技能實習制度的檢討，但實際現場仍然存在語言隔閡與生活環境配套不足等問題。", "word": "見直し" } ],
    [ { "text": "尤其在地方的中小企業中，不少企業若沒有外籍人才便無法維持營運，對他們的依賴已不再只是暫時性措施，而是逐漸成為一種結構性現象。", "word": "依存" } ],
    [ { "text": "另一方面，每當低薪與長工時等勞動環境問題被指出，接收制度本身的是非就成為議論焦點。", "word": "議論の的" } ],
    [ { "text": "人們開始要求轉換視角，不再只把外籍勞工視為勞動力的補充，而是將他們視為共生社會的一份子來接納。", "word": "共生社会" } ]
  ]
}
