  "translations": [
    [ { "text": "在生成式AI急速普及之中，教育現場對其應用的議論也日益熱烈。", "word": "生成AI" } ],
    [ { "text": "以往，在報告與作文的寫作上，使用生成AI往往被視為一種不當行為。", "word": "不正行為" } ],
    [ { "text": "然而近年來，也有人主張應積極將其作為整理思考與輔助發想的工具，論點逐漸從一律禁止轉向如何恰當地與其相處。", "word": "論点" } ],
    [ { "text": "話雖如此，過度依賴生成AI，讓自己思考、試錯的機會被剝奪，思考能力本身難以培養的擔憂依然根深蒂固。", "word": "懸念" } ],
    [ { "text": "事實上，根據某項調查，越是日常使用生成AI的學生，面對複雜問題時的堅持程度似乎越有下降的傾向，這項結果也已被報告。", "word": "粘り強さ" } ],
    [ { "text": "話雖如此，阻止技術進步並不現實，教育現場所需要的，或許是轉向如何以具有教育價值的方式將生成AI融入其中這個更具建設性的提問。", "word": "転換" } ],
    [ { "text": "今後，教師本身理解生成AI的特性，並摸索能培養批判性思考能力的指導方法，將比以往更加重要。", "word": "批判的思考力" } ]
  ]
