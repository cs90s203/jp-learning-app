  "translations": [
    [ { "text": "星期天，我和哥哥去湖邊划船了。", "word": "ボート" } ],
    [ { "text": "因為天氣很好，水面上感覺非常舒服。", "word": "気持ちいい" } ],
    [ { "text": "哥哥很擅長划船，我卻不會划，所以一直看風景、拍照片。", "word": "上手" } ],
    [ { "text": "途中看到魚跳起來，嚇了一跳。", "word": "びっくりする" } ],
    [ { "text": "雖然有點累，哥哥好像還想繼續玩。", "word": "疲れる" } ],
    [ { "text": "下次還想兩個人一起去。", "word": "思う" } ]
