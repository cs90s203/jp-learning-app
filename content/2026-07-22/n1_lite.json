    [ { "text": "在少子化持續發展之中，地方勞動力人口的減少，已不僅是單純的人口統計問題，而是可能動搖地區經濟存續根基的嚴重課題。", "word": "揺るがす" } ],
    [ { "text": "再加上年輕族群流向都市，地方中小企業要確保接班人與勞動人力也變得越來越困難。", "word": "確保" } ],
    [ { "text": "此外，消費人口的縮減會導致當地商店街衰退，容易陷入地區生活基礎本身逐漸喪失的惡性循環。", "word": "陥る" } ],
    [ { "text": "實際上，在人口過疏化持續的地方自治體中，甚至連維持公共交通工具都變得困難的地方也不少。", "word": "維持" } ],
    [ { "text": "要突破這樣的狀況，不能只擴充育兒支援，建構讓年輕人願意在地方定居的就業與生活環境也是不可或缺的。", "word": "整備する" } ],
    [ { "text": "若行政應對落於被動，地方經濟的縮小恐將進一步加速。", "word": "加速する" } ]
  ]
}
