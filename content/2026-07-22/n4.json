  "translations": [
    [ { "text": "上星期日，我和弟弟去附近的山上健行。", "word": "ハイキング" } ],
    [ { "text": "因為天氣很好，兩人都非常期待。", "word": "楽しみ" } ],
    [ { "text": "一邊走山路、一邊拍照，慢慢地往上爬。", "word": "登る" } ],
    [ { "text": "途中雖然累了，但弟弟鼓勵了我，所以能走到最後。", "word": "励ます" } ],
    [ { "text": "到達山頂後，能看到城鎮的景色，感到很感動。", "word": "感動する" } ],
    [ { "text": "雖然累，但開心到還想再來一次。", "word": "楽しい" } ]
