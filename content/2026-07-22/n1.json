  "translations": [
    [ { "text": "日本國內產生的食物浪費據稱一年高達數百萬噸，其削減長久以來已被視為刻不容緩的社會課題。", "word": "食品ロス" } ],
    [ { "text": "食物浪費之所以被視為問題，背後不僅是經濟上的損失，更在於從生產到廢棄的一連串過程中所產生的環境負荷令人擔憂。", "word": "環境負荷" } ],
    [ { "text": "從糧食的生產、運輸到廢棄的各個階段都耗費了大量的資源與能源，而其中大部分最終淪為浪費，這個事實不容忽視。", "word": "看過する" } ],
    [ { "text": "近年也有指出，社會大眾對賞味期限與消費期限差異的理解不足，導致過度廢棄，因此不僅是業者，消費者每一個人的意識改革也備受期待。", "word": "意識改革" } ],
    [ { "text": "此外，透過建立以食物銀行為首的剩餘食品再分配機制，將原本應被廢棄的食品送達有需要的人手中，這樣的行動也正在各地逐漸擴展。", "word": "取り組み" } ],
    [ { "text": "話雖如此，光靠這些行動並不能解決結構性的問題，若缺乏涵蓋生產、流通、消費各個階段的全面性對策，恐怕難以期待根本性的改善。", "word": "包括的" } ]
  ]
}
