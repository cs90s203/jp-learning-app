  "translations": [
    [ { "text": "從半年前開始，我去附近的攝影教室上課。", "word": "通い始める" } ],
    [ { "text": "原本對攝影沒什麼興趣，但朋友邀我「要不要一起試試看？」", "word": "誘う" } ],
