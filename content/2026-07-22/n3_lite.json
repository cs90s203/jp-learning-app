  "translations": [
    [ { "text": "上星期六，我稍微順道去了車站前正在舉辦的手作市集。", "word": "手作り市" } ],
    [ { "text": "飾品、陶器、手工編織的圍巾之類的東西擺成一整排，光是看著就很開心。", "word": "並ぶ" } ],
    [ { "text": "特別中意的，是一個木頭做的小盤子。", "word": "気に入る" } ],
