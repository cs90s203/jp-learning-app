  "translations": [
    [ { "text": "因經濟狀況等原因而無法充分獲得餐食的孩子們，近年來各地陸續出現以免費或低價提供餐食的「兒童食堂」。", "word": "子ども食堂" } ],
    [ { "text": "這原本是作為貧困對策的一環而展開的措施，如今也開始扮演起地區居民彼此交流場所的角色。", "word": "役割" } ],
    [ { "text": "實際上，獨自用餐的高齡者，以及為育兒煩惱的家長參加的案例也不少。", "word": "悩む" } ],
    [ { "text": "話雖如此，營運主要仰賴志工的善意支撐，不少團體都面臨資金與人力不足的課題。", "word": "支えられる" } ],
    [ { "text": "因此，要讓兒童食堂以永續的形式維持下去，除了行政上的財政支援之外，建立由地方社會整體共同支持的機制也是不可或缺的。", "word": "欠かせる" } ]
  ]
}
