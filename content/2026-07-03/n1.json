  "translations": [
    [ { "text": "支撐戰後日本經濟成長的終身雇用制度，", "word": "終身雇用制度" }, { "text": "近年來其前提本身正大幅動搖。", "word": "揺らぐ" } ],
    [ { "text": "過去曾有一種默契：只要對一家企業盡忠，就能獲得穩定的生活保障，", "word": "暗黙の了解" }, { "text": "這種默契支撐著勞資雙方的信賴關係。", "word": "信頼関係" } ],
    [ { "text": "然而，全球化與技術革新帶來的產業結構急速變化，", "word": "技術革新" }, { "text": "使企業難以維持傳統型的雇用方式，越來越多企業開始導入成果主義式的人事考核。", "word": "成果主義的" } ],
    [ { "text": "在這樣的潮流中，年輕世代的職涯觀也出現了顯著的變化。", "word": "キャリア観" } ],
    [ { "text": "比起將一生奉獻給一家公司的想法，", "word": "捧げる" }, { "text": "提升自己的市場價值、視需要將換工作視為選項之一的傾向正在增強。", "word": "転職" } ],
    [ { "text": "不過，與其說這種變化只是個人主義的抬頭，", "word": "個人主義" }, { "text": "或許更應該視為：終身雇用這種制度性保護逐漸淡化之下，人們不得不主動規劃自己職涯的現實所帶來的表現。", "word": "主体的" } ],
    [ { "text": "如今企業與個人的關係正被重新定義，", "word": "再定義する" }, { "text": "摸索出對雙方都可持續的雇用方式，已成為當務之急。", "word": "模索する" } ]
  ],
