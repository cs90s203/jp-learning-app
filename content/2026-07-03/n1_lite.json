  "translations": [
    [ { "text": "多語言教育作為培養孩子認知能力與跨文化理解的手段，", "word": "認知能力" }, { "text": "近年來越來越受到關注。", "word": "注目" } ],
    [ { "text": "研究結果指出，從幼年時期就接觸多種語言，", "word": "研究結果" }, { "text": "能提高大腦的柔軟性，培養出從多角度掌握新概念的能力。", "word": "多角的" } ],
    [ { "text": "實際上，也有人說在多語言環境下成長的孩子，", "word": "多言語環境" }, { "text": "更容易察覺到只用單一語言難以發現的表達差異。", "word": "気づく" } ],
    [ { "text": "另一方面，也有人指出，詞彙能力會因語言而分散，", "word": "語彙力" }, { "text": "導致每種語言都無法充分深化就長大的隱憂。", "word": "懸念" } ],
    [ { "text": "尤其當家庭中使用的語言和學校學習的語言不同時，", "word": "家庭内" }, { "text": "也不能否定這可能會影響孩子自我認同的形成。", "word": "アイデンティティ形成" } ],
    [ { "text": "因此，導入多語言教育時，不應只是單純增加語言數量，", "word": "導入する" }, { "text": "而必須建立能讓每種語言都充分習得的環境，這是不可或缺的。", "word": "不可欠" } ]
  ],
