  "translations": [
    [ { "text": "開始獨居生活之後，", "word": "一人暮らし" }, { "text": "雖然聽說飲食容易變得隨便，但實際上真的是這樣。", "word": "適当" } ],
    [ { "text": "一開始還努力自己煮飯，", "word": "自炊" }, { "text": "但隨著工作變忙，依賴超商便當的日子漸漸增加了。", "word": "コンビニ弁当" } ],
    [ { "text": "然而有一天，健康檢查指出我蔬菜攝取不足，", "word": "健康診断" }, { "text": "讓我覺得再這樣下去真的不行。", "word": "このまま" } ],
    [ { "text": "於是我決定試試看週末一次切好蔬菜、冷凍起來的方法。", "word": "冷凍する" } ],
    [ { "text": "雖然費工夫，但平日的負擔確實減少了不少，", "word": "負担" }, { "text": "總覺得身體也變輕鬆了。", "word": "軽い" } ]
