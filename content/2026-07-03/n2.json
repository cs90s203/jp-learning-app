  "translations": [
    [ { "text": "近年，許多企業開始解禁副業，", "word": "解禁する" }, { "text": "工作方式本身正在發生巨大的改變。", "word": "働き方" } ],
    [ { "text": "以往，副業常以妨礙本業為由而被禁止，", "word": "禁止する" }, { "text": "但隨著人才流動化與個人對提升技能的關注升高，這樣的態度也逐漸緩和了下來。", "word": "緩和する" } ],
    [ { "text": "實際上，也有不少人透過副業挑戰新領域，", "word": "挑戦する" }, { "text": "並將在那裡獲得的知識與人脈回饋給本業。", "word": "還元する" } ],
    [ { "text": "另一方面，也有不少人擔憂長時間勞動對健康的不良影響，以及資訊管理上的風險。", "word": "懸念する" } ],
    [ { "text": "因此，企業不能只是單純允許副業，", "word": "認める" }, { "text": "還必須建立管理工時的體制。", "word": "整備する" } ],
