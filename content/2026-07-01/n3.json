  "translations": [
    [
      { "text": "進入七月，", "word": "七月" },
      { "text": "日本各地開始了各種夏日活動。", "word": "行事" }
    ],
    [
      { "text": "煙火大會和盂蘭盆舞等，", "word": "花火大会" },
      { "text": "每個地區都舉辦各具特色的活動。", "word": "地域" }
    ],
    [
      { "text": "然而，最近參加者減少的地方越來越多。", "word": "参加者" }
    ],
    [
      { "text": "少子化和生活方式的變化被認為是原因。", "word": "原因" }
    ],
    [
      { "text": "即使如此，喜歡夏日祭典的人仍多，", "word": "夏祭り" },
      { "text": "想把當地文化傳承給下一代的人也不少。", "word": "伝える" }
    ],
    [
      { "text": "如何連結傳統與現代，", "word": "伝統" },
      { "text": "將是今後的課題吧。", "word": "課題" }
    ]
  ],
