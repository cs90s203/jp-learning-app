  "translations": [
    [
      { "text": "今天早上醒來，", "word": "覚める" },
      { "text": "窗外比平常明亮。", "word": "明るい" }
    ],
    [
      { "text": "打開窗簾一看，", "word": "開ける" },
      { "text": "藍天一片延伸開來。", "word": "広がる" }
    ],
    [
      { "text": "梅雨終於結束了。", "word": "梅雨" }
    ],
    [
      { "text": "久違的晴天讓心情也明朗起來。", "word": "気持ち" }
    ],
    [
      { "text": "把洗好的衣物曬到陽台，", "word": "干す" },
      { "text": "決定出去散步。", "word": "散歩" }
    ],
    [
      { "text": "公園裡孩子們活力十足地玩耍著。", "word": "子ども" }
    ],
    [
      { "text": "那是個感受到夏天正式開始的早晨。", "word": "感じる" }
