  "translations": [
    [
      { "text": "今年夏天也持續創紀錄的酷暑，", "word": "猛暑" },
      { "text": "電力供需緊繃令人擔憂。", "word": "電力需給" }
    ],
    [
      { "text": "因為下午冷氣使用集中的時段，電力消耗超過供給量的風險存在。", "word": "供給量" }
    ],
    [
      { "text": "對此，政府在呼籲節電的同時，也在研討導入可再生能源的促進措施。", "word": "再生可能エネルギー" }
    ],
    [
      { "text": "然而，太陽能發電受日照量左右有其限制，", "word": "制約" },
      { "text": "確保穩定供應被認為需要儲電技術的發展。", "word": "蓄電技術" }
    ],
    [
      { "text": "在基礎設施老朽化持續推進的情況下，不得不說建立可持續的能源政策是當務之急。", "word": "構築" }
    ],
    [
      { "text": "酷暑如今已成為與自然災害並列討論的時代了。", "word": "自然災害" }
    ]
  ],
