  "translations": [
    [
      { "text": "每到夏天，", "word": "夏" },
      { "text": "因中暑被緊急送醫的人急速增加。", "word": "熱中症" }
    ],
    [
      { "text": "尤其是老年人和戶外工作者需要特別注意。", "word": "高齢者" }
    ],
    [
      { "text": "根據專家表示，", "word": "専門家" },
      { "text": "勤加補充水分和適當休息是基本的預防措施。", "word": "予防策" }
    ],
    [
      { "text": "雖然很多人猶豫是否要使用冷氣，", "word": "ためらう" },
      { "text": "但因為室內也可能中暑，應積極加以利用。", "word": "活用" }
    ],
    [
      { "text": "外出時戴帽子或使用遮陽傘，", "word": "帽子" },
      { "text": "避免直射陽光也很重要。", "word": "直射日光" }
    ],
    [
      { "text": "察覺自己身體狀況的變化，", "word": "気づく" },
      { "text": "正是第一步。", "word": "第一歩" }
    ]
  ],
