  "translations": [
    [
      { "text": "由於網際網路與智慧型手機的普及，", "word": "普及" },
      { "text": "我們處於不斷暴露在龐大資訊中的環境裡。", "word": "さらす" }
    ],
    [
      { "text": "每當通知聲響起，注意力就會被打斷，", "word": "中断" },
      { "text": "要長時間專注於單一工作變得比以往更加困難，這樣的指摘已不再罕見。", "word": "集中" }
    ],
    [
      { "text": "在神經科學領域，有人敲響警鐘指出，", "word": "警鐘" },
      { "text": "這種斷斷續續的注意力切換會對大腦造成負擔，可能損害深層思考力與創造力。", "word": "思考力" }
    ],
    [
      { "text": "尤其令人擔憂的是，人們甚至逐漸失去了仔細斟酌資訊真偽的餘裕。", "word": "吟味" }
    ],
    [
      { "text": "囫圇吞棗地接受接二連三傳來的片段資訊，", "word": "鵜呑み" },
      { "text": "僅憑表面理解就做出判斷的危險性不容忽視。", "word": "危うさ" }
    ],
    [
      { "text": "話雖如此，把這種狀況單純歸咎於個人意志薄弱未免太過草率。", "word": "帰する" }
    ],
    [
      { "text": "考量到那些被設計成互相爭奪人們可自由支配時間的App與演算法確實存在，", "word": "可処分時間" },
      { "text": "問題的本質恐怕在於資訊環境本身的設計。", "word": "本質" }
    ],
    [
      { "text": "今後應該更需要從「如何將注意力視為一種資源並加以保護」的視角展開討論。", "word": "注意力" }
    ]
  ],
