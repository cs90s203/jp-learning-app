  "translations": [
    [
      { "text": "最近，覺得自己看手機的時間太長了，", "word": "長すぎる" },
      { "text": "於是決定只在週末挑戰數位排毒。", "word": "デジタルデトックス" }
    ],
    [
      { "text": "規則很簡單，從週六早上到週日晚上，", "word": "簡単" },
      { "text": "把所有通知都關掉，社群軟體也完全不打開。", "word": "SNS" }
    ],
    [
      { "text": "一開始靜不下心來，好幾次差點就要伸手去拿手機。", "word": "落ち着く" }
    ],
    [
      { "text": "但是過了半天左右，卻不可思議地漸漸不在意了。", "word": "不思議と" }
    ],
    [
      { "text": "取而代之的是看書、在附近散步，", "word": "代わり" },
      { "text": "度過這段時間時，感覺時間流逝得特別緩慢。", "word": "過ごす" }
    ],
    [
      { "text": "結束之後，發現腦袋比想像中更清爽，", "word": "すっきり" },
      { "text": "讓我覺得下週還想再試一次。", "word": "試す" }
    ]
  ],
