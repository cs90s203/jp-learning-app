  "translations": [
    [
      { "text": "上週日，我去幫忙祖母的家庭菜園。", "word": "家庭菜園" }
    ],
    [
      { "text": "祖母種著番茄和小黃瓜，", "word": "育てる" },
      { "text": "每天澆水、拔草。", "word": "抜く" }
    ],
    [
      { "text": "我一去，祖母就開心地教我蔬菜的栽種方法。", "word": "育て方" }
    ],
    [
      { "text": "因為發現了有蟲附著的葉子，", "word": "つく" },
      { "text": "我就輕輕地把牠清除掉。", "word": "取り除く" }
    ],
    [
      { "text": "自己種的蔬菜，比在店裡買的更新鮮好吃。", "word": "新鮮" }
    ],
    [
      { "text": "下個月我也打算去幫忙。", "word": "つもり" }
    ]
  ],
