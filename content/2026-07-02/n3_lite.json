  "translations": [
    [
      { "text": "我家的狗超愛散步，每天都想走同一條路線。", "word": "大好き" }
    ],
    [
      { "text": "但是從上週開始，我試著一點一點改變路線。", "word": "変える" }
    ],
    [
      { "text": "一開始牠似乎有點不知所措，", "word": "戸惑う" },
      { "text": "但後來好像開始對新的氣味和風景產生了興趣。", "word": "興味" }
    ],
    [
      { "text": "牠特別喜歡沿著河邊的那條路，", "word": "気に入る" },
      { "text": "一到那裡就用力搖尾巴。", "word": "尻尾" }
    ],
    [
      { "text": "光是改變散步路線，狗竟然也能變得這麼開心，讓我有了新發現。", "word": "気づく" }
    ],
    [
      { "text": "今後也想配合季節，嘗試各種不同的路線。", "word": "試す" }
    ]
  ],
