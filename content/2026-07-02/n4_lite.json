  "translations": [
    [
      { "text": "每天早上都在附近的公園做廣播體操。", "word": "ラジオ体操" }
    ],
    [
      { "text": "一到六點半，音樂就會開始播放。", "word": "六時半" }
    ],
    [
      { "text": "附近的長輩和小孩都會聚在一起，", "word": "お年寄り" },
      { "text": "一起活動身體。", "word": "動かす" }
    ],
    [
      { "text": "一開始有點害羞，", "word": "恥ずかしい" },
      { "text": "現在已經習慣了。", "word": "慣れる" }
    ],
    [
      { "text": "體操結束後，大家會聊一下天。", "word": "話" }
    ],
