  "translations": [
    [ { "text": "以人口減少和高齡化不斷加劇的地方城市為中心，所有者不明而遭放任不管的空屋增加，已成為嚴重的社會問題。", "word": "空き家" } ],
    [ { "text": "倒塌的危險、治安惡化、景觀受損等，空屋帶來的弊病涉及多方面，對周邊居民的生活環境也造成了不小的影響。", "word": "弊害" } ],
    [ { "text": "其背景在於繼承所伴隨的權利關係複雜化，以及所有者想避免負擔拆除費用等情況，即使行政機關要求改正，也難以形成具有實效性的應對，這是一種結構性的課題。", "word": "構造的" } ],
    [ { "text": "為了突破這種狀況，一部分地方自治體正推動將空屋翻新為面向移居者的住所或地區交流據點的嘗試，逐漸出現不僅止於消除問題、而是將空屋重新視為提升地區魅力之資源的想法。", "word": "捉え直す" } ],
    [ { "text": "不過，要將這類做法發展成可持續的機制，仍有財源確保、專業人才培育、法律制度完善等不少需要克服的課題。", "word": "持続的" } ],
    [ { "text": "圍繞空屋的討論，或許有必要不只當作單純的不動產問題，而是作為重新反思今後地區社會應有樣貌的契機來看待。", "word": "問い直す" } ]
  ]
