  "translations": [
    [ { "text": "關於沒有飼主、俗稱流浪貓的貓咪，各地一直指出因餵食而起的鄰里糾紛，以及無秩序繁殖等問題。", "word": "野良猫" } ],
    [ { "text": "在這樣的背景下受到關注的，是由當地居民和志工合作，為貓咪施行絕育手術後，將牠們視為僅此一代的生命來守護的「地區貓咪照護活動」。", "word": "地域猫活動" } ],
    [ { "text": "這項做法不僅止於保護貓咪，也重視透過徹底管理飼料與廁所，來維持周邊環境的衛生與美觀。", "word": "重視する" } ],
    [ { "text": "行政與居民攜手合作的地方自治體也在增加，透過制定條例與指導方針來推動這項活動的動向也可以看到。", "word": "後押しする" } ],
    [ { "text": "不過，推動者的高齡化與資金不足等課題依然存在，建立可持續的機制似乎將成為今後的焦點。", "word": "持続可能" } ]
  ]
}
