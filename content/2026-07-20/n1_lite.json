    [ { "text": "透過外送代辦或共乘服務等平台承接單次工作、所謂的零工工作者，近年急遽增加。", "word": "ギグワーカー" } ],
    [ { "text": "不受時間與地點束縛就能工作的自由度雖是一大魅力，但另一方面，由於多數情況採取的是業務委外而非雇傭契約的形式，因此有人指出，勞工無法充分獲得職災保險、最低薪資等勞動法上的保障。", "word": "労働法上" } ],
    [ { "text": "收入容易變得不穩定這一點也不容忽視，不少人一旦搞壞身體無法工作，就會面臨收入中斷的危險性。", "word": "危うさ" } ],
    [ { "text": "實際上，在歐洲和部分國家，已出現將這類平台勞動者定位為獨立的法律類別、建立最低限度社會保障的動向。", "word": "社会保障" } ],
    [ { "text": "隨著這種工作方式越來越普及，該如何重新檢視既有的勞動法制，整個社會恐怕都有必要深入討論。", "word": "見直す" } ]
