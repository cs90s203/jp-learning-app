  "translations": [
    [
      {
        "text": "在日本的鄉下，",
        "word": "地方"
      },
      {
        "text": "年輕人",
        "word": "若者"
      },
      {
        "text": "往都市的外流",
        "word": "流出"
      },
      {
        "text": "止不住，",
        "word": "止まる"
      },
      {
        "text": "人口減少",
        "word": "減少"
      },
      {
        "text": "與高齡化",
        "word": "高齢化"
      },
      {
        "text": "成了嚴重的課題。",
        "word": "課題"
      }
    ],
    [
      {
        "text": "曾經",
        "word": "かつて"
      },
      {
        "text": "充滿活力的",
        "word": "活気"
      },
      {
        "text": "商店街，",
        "word": "商店街"
      },
      {
        "text": "如今拉下鐵門的",
        "word": "シャッター"
      },
      {
        "text": "店家也很顯眼，",
        "word": "目立つ"
      },
      {
        "text": "連維持地方的傳統",
        "word": "伝統"
      },
      {
        "text": "活動都變得困難。",
        "word": "行事"
      }
    ],
    [
      {
        "text": "為了打開",
        "word": "打開"
      },
      {
        "text": "這樣的局面，",
        "word": "こうした"
      },
      {
        "text": "各自治體",
        "word": "各自治体"
      },
      {
        "text": "正推動招攬移居者、",
        "word": "誘致"
      },
      {
        "text": "完善遠距工作",
        "word": "テレワーク"
      },
      {
        "text": "環境等各種措施。",
        "word": "取り組み"
      }
    ],
    [
      {
        "text": "其中也能看到",
        "word": "見る"
      },
      {
        "text": "翻修空屋",
        "word": "空き家"
      },
      {
        "text": "便宜租給年輕世代的",
        "word": "世代"
      },
      {
        "text": "嘗試，",
        "word": "試み"
      },
      {
        "text": "以及把當地特產",
        "word": "特産品"
      },
      {
        "text": "透過網路向全國發送的案例。",
        "word": "発信"
      }
    ],
    [
      {
        "text": "不過，",
        "word": "もっとも"
      },
      {
        "text": "要在一朝一夕間",
        "word": "一朝一夕"
      },
      {
        "text": "改變人口的趨勢",
        "word": "流れ"
      },
      {
        "text": "並不容易。",
        "word": "容易"
      }
    ],
    [
      {
        "text": "話雖如此，",
        "word": "とはいえ"
      },
      {
        "text": "那段進程",
        "word": "歩み"
      },
      {
        "text": "絕非",
        "word": "決して"
      },
      {
        "text": "一帆風順。",
        "word": "平坦"
      }
    ],
    [
      {
        "text": "堅持不懈地",
        "word": "粘り強い"
      },
      {
        "text": "持續磨練",
        "word": "磨く"
      },
      {
        "text": "地方魅力的",
